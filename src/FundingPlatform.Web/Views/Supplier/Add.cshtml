@model FundingPlatform.Web.ViewModels.AddSupplierViewModel

@{
    ViewData["Title"] = "Add Supplier with Quotation";
}

<h2>Add Supplier with Quotation</h2>

<div class="row">
    <div class="col-md-8">
        <form asp-controller="Supplier" asp-action="Add" asp-route-appId="@Model.ApplicationId" asp-route-itemId="@Model.ItemId" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger"></div>

            <input type="hidden" asp-for="ApplicationId" />
            <input type="hidden" asp-for="ItemId" />

            <h4>Supplier Information</h4>
            <hr />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="SupplierLegalId" class="form-label"></label>
                    <input asp-for="SupplierLegalId" class="form-control" />
                    <span asp-validation-for="SupplierLegalId" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="SupplierName" class="form-label"></label>
                    <input asp-for="SupplierName" class="form-control" />
                    <span asp-validation-for="SupplierName" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="ContactName" class="form-label"></label>
                    <input asp-for="ContactName" class="form-control" />
                    <span asp-validation-for="ContactName" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" type="tel" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Location" class="form-label"></label>
                    <input asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="HasElectronicInvoice" class="form-check-input" type="checkbox" />
                <label asp-for="HasElectronicInvoice" class="form-check-label"></label>
            </div>

            <div class="mb-3">
                <label asp-for="ShippingDetails" class="form-label"></label>
                <textarea asp-for="ShippingDetails" class="form-control" rows="2"></textarea>
                <span asp-validation-for="ShippingDetails" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="WarrantyInfo" class="form-label"></label>
                <textarea asp-for="WarrantyInfo" class="form-control" rows="2"></textarea>
                <span asp-validation-for="WarrantyInfo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ComplianceStatus" class="form-label"></label>
                <input asp-for="ComplianceStatus" class="form-control" />
                <span asp-validation-for="ComplianceStatus" class="text-danger"></span>
            </div>

            <h4 class="mt-4">Quotation Details</h4>
            <hr />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ValidUntil" class="form-label"></label>
                    <input asp-for="ValidUntil" class="form-control" type="date" />
                    <span asp-validation-for="ValidUntil" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="QuotationFile" class="form-label"></label>
                <input asp-for="QuotationFile" class="form-control" type="file" />
                <span asp-validation-for="QuotationFile" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Add Supplier and Quotation</button>
            <a asp-controller="Application" asp-action="Details" asp-route-id="@Model.ApplicationId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
