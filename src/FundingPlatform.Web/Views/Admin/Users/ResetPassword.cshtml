@using FundingPlatform.Web.ViewModels.Admin
@model AdminUserResetPasswordViewModel
@{
    ViewData["Title"] = "Restablecer contraseña";
}

<div data-testid="admin-area">
    @await Html.PartialAsync("Components/_PageHeader",
        new PageHeaderViewModel(
            Title: $"Restablecer contraseña — {Model.TargetEmail}",
            Subtitle: "Se solicitará al usuario cambiar esta contraseña temporal al iniciar sesión.",
            Breadcrumbs: new[]
            {
                new BreadcrumbItem("Usuarios", Url.Action("Index", "AdminUsers")),
                new BreadcrumbItem("Restablecer contraseña"),
            }))

    <form method="post" asp-action="ResetPassword" asp-route-id="@Model.UserId" class="row" data-testid="admin-user-reset-form">
        @Html.AntiForgeryToken()
        <input asp-for="UserId" type="hidden" />
        <input asp-for="TargetEmail" type="hidden" />
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="col-md-6 mb-3">
            <label class="form-label" asp-for="NewTemporaryPassword">Nueva contraseña temporal</label>
            <input asp-for="NewTemporaryPassword" class="form-control" type="password" autocomplete="new-password" />
            <span asp-validation-for="NewTemporaryPassword" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label" asp-for="ConfirmPassword">Confirmar nueva contraseña</label>
            <input asp-for="ConfirmPassword" class="form-control" type="password" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-2">
            <a class="btn btn-secondary" href="@Url.Action("Index", "AdminUsers")">Cancelar</a>
            <button type="submit"
                    class="btn btn-warning"
                    data-testid="admin-user-reset-submit"
                    onclick="return confirm('¿Restablecer la contraseña de @Model.TargetEmail? Se cerrará su sesión inmediatamente.');">
                Restablecer contraseña
            </button>
        </div>
    </form>
</div>
