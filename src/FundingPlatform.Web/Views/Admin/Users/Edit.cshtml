@using FundingPlatform.Web.ViewModels.Admin
@model AdminUserEditViewModel
@{
    ViewData["Title"] = "Editar usuario";
    var roles = new[] { "Applicant", "Reviewer", "Admin" };
    string RoleLabel(string r) => r switch
    {
        "Applicant" => "Solicitante",
        "Reviewer" => "Revisor",
        "Admin" => "Administrador",
        _ => r,
    };
}

<div data-testid="admin-area">
    @await Html.PartialAsync("Components/_PageHeader",
        new PageHeaderViewModel(
            Title: $"Editar usuario — {Model.Email}",
            Breadcrumbs: new[]
            {
                new BreadcrumbItem("Usuarios", Url.Action("Index", "AdminUsers")),
                new BreadcrumbItem("Editar"),
            }))

    <form method="post" asp-action="Edit" asp-route-id="@Model.UserId" class="row" data-testid="admin-user-edit-form">
        @Html.AntiForgeryToken()
        <input asp-for="UserId" type="hidden" />
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="col-md-6 mb-3">
            <label class="form-label" asp-for="FirstName">Nombre</label>
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label" asp-for="LastName">Apellidos</label>
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label" asp-for="Email">Correo electrónico</label>
            <input asp-for="Email" class="form-control" type="email" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label" asp-for="Phone">Teléfono (opcional)</label>
            <input asp-for="Phone" class="form-control" type="tel" />
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label" asp-for="Role">Rol</label>
            <select asp-for="Role" class="form-select" id="roleSelect" data-testid="admin-user-role">
                @foreach (var r in roles)
                {
                    <option value="@r" selected="@(Model.Role == r)">@RoleLabel(r)</option>
                }
            </select>
            <span asp-validation-for="Role" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3" data-testid="legalid-field" id="legalIdField">
            <label class="form-label" asp-for="LegalId">Cédula</label>
            <input asp-for="LegalId" class="form-control" />
            <span asp-validation-for="LegalId" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between mt-2">
            <a class="btn btn-outline-secondary"
               data-testid="admin-user-edit-reset-password-link"
               href="@Url.Action("ResetPassword", "AdminUsers", new { id = Model.UserId })">
                <i class="ti ti-key"></i> Restablecer contraseña
            </a>
            <div class="d-flex gap-2">
                <a class="btn btn-secondary" href="@Url.Action("Index", "AdminUsers")">Cancelar</a>
                <button type="submit" class="btn btn-primary" data-testid="admin-user-edit-submit">Guardar cambios</button>
            </div>
        </div>
    </form>
</div>

<script>
    (function () {
        var roleSelect = document.getElementById('roleSelect');
        var legalField = document.getElementById('legalIdField');
        function updateLegalIdVisibility() {
            if (!roleSelect || !legalField) return;
            legalField.style.display = roleSelect.value === 'Applicant' ? '' : 'none';
        }
        if (roleSelect) {
            roleSelect.addEventListener('change', updateLegalIdVisibility);
            updateLegalIdVisibility();
        }
    })();
</script>
