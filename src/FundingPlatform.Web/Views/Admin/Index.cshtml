@{
    ViewData["Title"] = "Admin Dashboard";
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(Title: "Admin Dashboard"))

<div class="row row-cards mt-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-2">
                    <span class="text-secondary me-2"><i class="ti ti-template" style="font-size: 1.5rem;"></i></span>
                    <h5 class="card-title mb-0">Impact Templates</h5>
                </div>
                <p class="card-text text-secondary">Create and manage impact assessment templates and their parameters.</p>
                <a asp-action="ImpactTemplates" class="btn btn-primary">
                    <i class="ti ti-arrow-right me-1"></i>Manage Templates
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-2">
                    <span class="text-secondary me-2"><i class="ti ti-settings" style="font-size: 1.5rem;"></i></span>
                    <h5 class="card-title mb-0">System Configuration</h5>
                </div>
                <p class="card-text text-secondary">View and update system-wide configuration settings.</p>
                <a asp-action="Configuration" class="btn btn-primary">
                    <i class="ti ti-arrow-right me-1"></i>Manage Configuration
                </a>
            </div>
        </div>
    </div>
</div>
