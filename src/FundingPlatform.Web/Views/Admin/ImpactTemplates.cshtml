@model FundingPlatform.Web.ViewModels.ImpactTemplateAdminViewModel

@{
    ViewData["Title"] = "Plantillas de impacto";
    var headerActions = new[]
    {
        new ActionItem("Crear nueva plantilla", ActionClass.Primary,
            Url: Url.Action("CreateTemplate"),
            Icon: "ti ti-plus"),
    };
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: "Plantillas de impacto",
        Breadcrumbs: new[]
        {
            new BreadcrumbItem("Panel de administración", Url.Action("Index")),
            new BreadcrumbItem("Plantillas de impacto"),
        },
        PrimaryActions: headerActions))

@if (Model.Templates.Count == 0)
{
    @await Html.PartialAsync("Components/_EmptyState",
        new EmptyStateViewModel(
            Headline: "Aún no hay plantillas de impacto",
            Body: "Cree su primera plantilla de evaluación de impacto para comenzar a recopilar datos estructurados de impacto en los ítems.",
            Icon: "ti ti-template",
            PrimaryAction: new ActionItem("Crear nueva plantilla", ActionClass.Primary,
                Url: Url.Action("CreateTemplate"),
                Icon: "ti ti-plus")))
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table card-table table-vcenter">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Parámetros</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var template in Model.Templates)
                    {
                        <tr>
                            <td>@template.Name</td>
                            <td>@(template.Description ?? "-")</td>
                            <td>@template.ParameterCount</td>
                            <td>
                                @if (template.IsActive)
                                {
                                    <span class="status status-green"><i class="ti ti-check"></i> Activa</span>
                                }
                                else
                                {
                                    <span class="status status-secondary"><i class="ti ti-circle"></i> Inactiva</span>
                                }
                            </td>
                            <td>
                                <a asp-action="EditTemplate" asp-route-id="@template.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="ti ti-edit me-1"></i>Editar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
