@model FundingPlatform.Web.ViewModels.SystemConfigurationViewModel

@{
    ViewData["Title"] = "Configuración del sistema";
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: "Configuración del sistema",
        Subtitle: "Vea y actualice los parámetros de configuración del sistema",
        Breadcrumbs: new[]
        {
            new BreadcrumbItem("Panel de administración", Url.Action("Index")),
            new BreadcrumbItem("Configuración del sistema"),
        }))

@if (Model.Configurations.Count == 0)
{
    @await Html.PartialAsync("Components/_EmptyState",
        new EmptyStateViewModel(
            Headline: "No se encontraron configuraciones del sistema",
            Body: "Las configuraciones aparecerán aquí cuando se hayan sembrado en la base de datos.",
            Icon: "ti ti-settings-off"))
}
else
{
    <form asp-action="Configuration" method="post">
        @Html.AntiForgeryToken()

        <div class="card">
            <div class="table-responsive">
                <table class="table card-table table-vcenter">
                    <thead>
                        <tr>
                            <th>Clave</th>
                            <th>Valor</th>
                            <th>Descripción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Configurations.Count; i++)
                        {
                            <tr>
                                <td>
                                    <input type="hidden" name="Configurations[@i].Id" value="@Model.Configurations[i].Id" />
                                    <input type="hidden" name="Configurations[@i].Key" value="@Model.Configurations[i].Key" />
                                    <input type="hidden" name="Configurations[@i].Description" value="@Model.Configurations[i].Description" />
                                    <strong>@Model.Configurations[i].Key</strong>
                                </td>
                                <td>
                                    <input name="Configurations[@i].Value" value="@Model.Configurations[i].Value" class="form-control" required />
                                </td>
                                <td class="text-secondary">@(Model.Configurations[i].Description ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary">
                <i class="ti ti-device-floppy me-1"></i>Guardar configuración
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="ti ti-arrow-left me-1"></i>Volver al panel
            </a>
        </div>
    </form>
}
