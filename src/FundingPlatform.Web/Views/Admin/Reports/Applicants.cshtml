@model FundingPlatform.Web.ViewModels.Admin.Reports.ApplicantsViewModel
@{
    ViewData["Title"] = "Reporte de solicitantes";
    var req = Model.Result.AppliedFilter;
    var totalPages = Model.TotalPages;
    var page = Model.CurrentPage;
}

<div data-testid="admin-area">
    @await Html.PartialAsync("Components/_PageHeader",
        new PageHeaderViewModel(
            Title: "Solicitantes",
            Subtitle: $"{Model.Result.TotalCount} solicitante(s) coinciden con el filtro actual."))

    @await Html.PartialAsync("Components/_ReportSubTabs", "Applicants")

    <form method="get" class="card mt-3" data-testid="applicants-filter">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label" for="search">Buscar</label>
                    <input type="text" id="search" name="search" class="form-control"
                           value="@req.Search" data-testid="applicants-filter-search" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="hasExecutedAgreement">Con convenio ejecutado</label>
                    <select id="hasExecutedAgreement" name="hasExecutedAgreement" class="form-select">
                        <option value="" selected="@(req.HasExecutedAgreement is null)">— Cualquiera</option>
                        <option value="true" selected="@(req.HasExecutedAgreement == true)">Sí</option>
                        <option value="false" selected="@(req.HasExecutedAgreement == false)">No</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary" data-testid="applicants-filter-apply">Aplicar</button>
                    <a class="btn btn-outline-secondary"
                       href="@Url.Action("ExportApplicants", new { search = req.Search, hasExecutedAgreement = req.HasExecutedAgreement, sort = req.Sort })"
                       data-testid="applicants-export-csv">Descargar CSV</a>
                </div>
            </div>
        </div>
    </form>

    @if (Model.Result.Rows.Count == 0)
    {
        <div class="mt-3">
            @await Html.PartialAsync("Components/_EmptyState",
                new EmptyStateViewModel(
                    Headline: "Ningún solicitante coincide",
                    Body: "Ajuste el filtro e inténtelo nuevamente.",
                    Icon: "ti ti-mood-empty"))
        </div>
    }
    else
    {
        <div class="card mt-3" data-testid="applicants-table">
            <div class="table-responsive">
                <table class="table card-table table-vcenter">
                    <thead>
                        <tr>
                            <th>Nombre completo</th>
                            <th>Cédula</th>
                            <th>Correo electrónico</th>
                            <th>Total de solicitudes</th>
                            <th>Resueltas</th>
                            <th>Respuesta finalizada</th>
                            <th>Ejecutadas</th>
                            <th>Tasa de aprobación</th>
                            <th>Aprobado</th>
                            <th>Monto ejecutado</th>
                            <th>Última actividad</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Result.Rows)
                        {
                            <tr data-testid="applicants-row" data-applicant-legal-id="@row.LegalId">
                                <td>@row.FullName</td>
                                <td>@row.LegalId</td>
                                <td>@row.Email</td>
                                <td>@row.TotalApps</td>
                                <td>@row.ResolvedCount</td>
                                <td>@row.ResponseFinalizedCount</td>
                                <td>@row.AgreementExecutedCount</td>
                                <td>@(row.ApprovalRate.HasValue ? row.ApprovalRate.Value.ToString("P0") : "—")</td>
                                <td>
                                    @if (row.TotalApproved.Count == 0) { <span class="text-secondary">—</span> }
                                    else { foreach (var ca in row.TotalApproved) { <div data-currency="@ca.Currency"><span class="fw-semibold">@ca.Currency</span> @ca.Amount.ToString("N2")</div> } }
                                </td>
                                <td>
                                    @if (row.TotalExecuted.Count == 0) { <span class="text-secondary">—</span> }
                                    else { foreach (var ca in row.TotalExecuted) { <div data-currency="@ca.Currency"><span class="fw-semibold">@ca.Currency</span> @ca.Amount.ToString("N2")</div> } }
                                </td>
                                <td>@(row.LastActivity?.ToString("dd/MM/yyyy") ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (totalPages > 1)
        {
            <ul class="pagination mt-3" data-testid="applicants-pagination">
                @for (var p = 1; p <= totalPages; p++)
                {
                    var routeValues = new RouteValueDictionary
                    {
                        ["search"]               = req.Search,
                        ["hasExecutedAgreement"] = req.HasExecutedAgreement,
                        ["sort"]                 = req.Sort,
                        ["page"]                 = p,
                    };
                    <li class="page-item @(p == page ? "active" : null)">
                        <a class="page-link" href="@Url.Action("Applicants", routeValues)">@p</a>
                    </li>
                }
            </ul>
        }
    }
</div>
