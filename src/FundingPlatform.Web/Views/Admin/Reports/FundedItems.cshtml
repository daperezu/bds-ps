@model FundingPlatform.Web.ViewModels.Admin.Reports.FundedItemsViewModel
@{
    ViewData["Title"] = "Reporte de ítems financiados";
    var req = Model.Result.AppliedFilter;
    var totalPages = Model.TotalPages;
    var page = Model.CurrentPage;
}

<div data-testid="admin-area">
    @await Html.PartialAsync("Components/_PageHeader",
        new PageHeaderViewModel(
            Title: "Ítems financiados",
            Subtitle: $"{Model.Result.TotalCount} ítem(s) financiado(s) coinciden con el filtro actual."))

    @await Html.PartialAsync("Components/_ReportSubTabs", "FundedItems")

    <form method="get" class="card mt-3" data-testid="funded-items-filter">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label" for="approvedFrom">Aprobado desde</label>
                    <input type="date" id="approvedFrom" name="approvedFrom" class="form-control"
                           value="@(req.ApprovedFrom?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="approvedTo">Aprobado hasta</label>
                    <input type="date" id="approvedTo" name="approvedTo" class="form-control"
                           value="@(req.ApprovedTo?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3 form-check mt-4">
                    <input type="checkbox" id="executedOnly" name="executedOnly" value="true" class="form-check-input"
                           checked="@req.ExecutedOnly" data-testid="funded-items-filter-executedonly" />
                    <label for="executedOnly" class="form-check-label">Solo ejecutados</label>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary" data-testid="funded-items-filter-apply">Aplicar</button>
                    <a class="btn btn-outline-secondary"
                       href="@Url.Action("ExportFundedItems", new
                       {
                           categoryIds = req.CategoryIds,
                           supplierIds = req.SupplierIds,
                           appStates   = req.AppStates.Select(s => s.ToString()).ToArray(),
                           approvedFrom = req.ApprovedFrom?.ToString("yyyy-MM-dd"),
                           approvedTo   = req.ApprovedTo?.ToString("yyyy-MM-dd"),
                           executedOnly = req.ExecutedOnly,
                           sort = req.Sort
                       })"
                       data-testid="funded-items-export-csv">Descargar CSV</a>
                </div>
            </div>
        </div>
    </form>

    @if (Model.Result.Rows.Count == 0)
    {
        <div class="mt-3">
            @await Html.PartialAsync("Components/_EmptyState",
                new EmptyStateViewModel(
                    Headline: "Ningún ítem financiado coincide",
                    Body: "Ajuste el filtro e inténtelo nuevamente.",
                    Icon: "ti ti-mood-empty"))
        </div>
    }
    else
    {
        <div class="card mt-3" data-testid="funded-items-table">
            <div class="table-responsive">
                <table class="table card-table table-vcenter">
                    <thead>
                        <tr>
                            <th>N.º solicitud</th>
                            <th>Solicitante</th>
                            <th>Ítem</th>
                            <th>Categoría</th>
                            <th>Proveedor</th>
                            <th>Precio</th>
                            <th>Moneda</th>
                            <th>Estado de la solicitud</th>
                            <th>Enviada</th>
                            <th>Aprobada</th>
                            <th>Convenio</th>
                            <th>Ejecutada</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Result.Rows)
                        {
                            <tr data-testid="funded-items-row" data-app-id="@row.AppId">
                                <td>@row.AppId</td>
                                <td>@row.ApplicantFullName</td>
                                <td>@row.ItemProductName</td>
                                <td>@row.CategoryName</td>
                                <td>@row.SupplierName</td>
                                <td>@row.Price.ToString("N2")</td>
                                <td><span class="fw-semibold">@row.Currency</span></td>
                                <td>@row.AppState</td>
                                <td>@(row.AppSubmittedAt?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>@(row.ApprovedAt?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>@(row.HasAgreement ? "Sí" : "No")</td>
                                <td>@(row.Executed ? "Sí" : "No")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (totalPages > 1)
        {
            <ul class="pagination mt-3" data-testid="funded-items-pagination">
                @for (var p = 1; p <= totalPages; p++)
                {
                    var routeValues = new RouteValueDictionary
                    {
                        ["categoryIds"]  = req.CategoryIds,
                        ["supplierIds"]  = req.SupplierIds,
                        ["appStates"]    = req.AppStates.Select(s => s.ToString()).ToArray(),
                        ["approvedFrom"] = req.ApprovedFrom?.ToString("yyyy-MM-dd"),
                        ["approvedTo"]   = req.ApprovedTo?.ToString("yyyy-MM-dd"),
                        ["executedOnly"] = req.ExecutedOnly,
                        ["sort"]         = req.Sort,
                        ["page"]         = p,
                    };
                    <li class="page-item @(p == page ? "active" : null)">
                        <a class="page-link" href="@Url.Action("FundedItems", routeValues)">@p</a>
                    </li>
                }
            </ul>
        }
    }
</div>
