@model FundingPlatform.Web.ViewModels.Admin.Reports.ApplicationsViewModel
@using FundingPlatform.Domain.Enums
@{
    ViewData["Title"] = "Applications report";
    var req = Model.Result.AppliedFilter;
    var totalPages = Model.TotalPages;
    var page = Model.CurrentPage;
}

<div data-testid="admin-area">
    @await Html.PartialAsync("Components/_PageHeader",
        new PageHeaderViewModel(
            Title: "Applications",
            Subtitle: $"{Model.Result.TotalCount} application(s) match the current filter."))

    @await Html.PartialAsync("Components/_ReportSubTabs", "Applications")

    <form method="get" class="card mt-3" data-testid="applications-filter">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label" for="search">Search</label>
                    <input type="text" id="search" name="search" class="form-control"
                           value="@req.Search" data-testid="applications-filter-search" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="from">From</label>
                    <input type="date" id="from" name="from" class="form-control"
                           value="@(req.From?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="to">To</label>
                    <input type="date" id="to" name="to" class="form-control"
                           value="@(req.To?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">State</label>
                    <select name="states" class="form-select" multiple size="3" data-testid="applications-filter-states">
                        @foreach (var s in Enum.GetValues<ApplicationState>())
                        {
                            var sel = req.States.Contains(s);
                            <option value="@s" selected="@sel">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary" data-testid="applications-filter-apply">Apply</button>
                    <a class="btn btn-outline-secondary"
                       href="@Url.Action("ExportApplications", new
                       {
                           states     = req.States.Select(s => s.ToString()).ToArray(),
                           from       = req.From?.ToString("yyyy-MM-dd"),
                           to         = req.To?.ToString("yyyy-MM-dd"),
                           search     = req.Search,
                           hasAgreement = req.HasAgreement,
                           hasActiveAppeal = req.HasActiveAppeal,
                           sort       = req.Sort
                       })"
                       data-testid="applications-export-csv">Download CSV</a>
                </div>
            </div>
        </div>
    </form>

    @if (Model.Result.Rows.Count == 0)
    {
        <div class="mt-3">
            @await Html.PartialAsync("Components/_EmptyState",
                new EmptyStateViewModel(
                    Headline: "No applications match",
                    Body: "Adjust the filter and try again.",
                    Icon: "ti ti-mood-empty"))
        </div>
    }
    else
    {
        <div class="card mt-3" data-testid="applications-table">
            <div class="table-responsive">
                <table class="table card-table table-vcenter">
                    <thead>
                        <tr>
                            <th>App Id</th>
                            <th>Applicant</th>
                            <th>Legal Id</th>
                            <th>State</th>
                            <th>Created</th>
                            <th>Submitted</th>
                            <th>Items</th>
                            <th>Approved</th>
                            <th>Agreement</th>
                            <th>Appeal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Result.Rows)
                        {
                            <tr data-testid="applications-row" data-app-id="@row.AppId">
                                <td>@row.AppId</td>
                                <td>@row.ApplicantFullName</td>
                                <td>@row.ApplicantLegalId</td>
                                <td>@row.State</td>
                                <td>@row.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>@(row.SubmittedAt?.ToString("yyyy-MM-dd") ?? "—")</td>
                                <td>@row.ItemCount</td>
                                <td>
                                    @if (row.TotalApproved.Count == 0)
                                    {
                                        <span class="text-secondary">—</span>
                                    }
                                    else
                                    {
                                        @foreach (var ca in row.TotalApproved)
                                        {
                                            <div data-currency="@ca.Currency"><span class="fw-semibold">@ca.Currency</span> @ca.Amount.ToString("N2")</div>
                                        }
                                    }
                                </td>
                                <td>@(row.HasAgreement ? "Yes" : "No")</td>
                                <td>@(row.HasActiveAppeal ? "Yes" : "No")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (totalPages > 1)
        {
            <ul class="pagination mt-3" data-testid="applications-pagination">
                @for (var p = 1; p <= totalPages; p++)
                {
                    var routeValues = new RouteValueDictionary
                    {
                        ["states"]          = req.States.Select(s => s.ToString()).ToArray(),
                        ["from"]            = req.From?.ToString("yyyy-MM-dd"),
                        ["to"]              = req.To?.ToString("yyyy-MM-dd"),
                        ["search"]          = req.Search,
                        ["hasAgreement"]    = req.HasAgreement,
                        ["hasActiveAppeal"] = req.HasActiveAppeal,
                        ["sort"]            = req.Sort,
                        ["page"]            = p,
                    };
                    <li class="page-item @(p == page ? "active" : null)">
                        <a class="page-link" href="@Url.Action("Applications", routeValues)">@p</a>
                    </li>
                }
            </ul>
        }
    }
</div>
