@model FundingPlatform.Web.ViewModels.FundingAgreementDocumentViewModel
@{
    var culture = System.Globalization.CultureInfo.GetCultureInfo(Model.LocaleCode);
    string Money(decimal value)
    {
        return $"{value.ToString("N2", culture)} {Model.CurrencyIsoCode}";
    }
}

<h2>Funded Items</h2>
<table class="items">
    <thead>
        <tr>
            <th>Product</th>
            <th>Category</th>
            <th>Supplier</th>
            <th class="amount">Unit Price</th>
            <th class="amount">Line Total</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.CategoryName</td>
                <td>@item.SupplierName</td>
                <td class="amount">@Money(item.UnitPrice)</td>
                <td class="amount">@Money(item.LineTotal)</td>
            </tr>
        }
        <tr class="total-row">
            <td colspan="4">Total</td>
            <td class="amount">@Money(Model.TotalAmount)</td>
        </tr>
    </tbody>
</table>
