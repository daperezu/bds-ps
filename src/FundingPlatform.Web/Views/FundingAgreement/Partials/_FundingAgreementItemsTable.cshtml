@model FundingPlatform.Web.ViewModels.FundingAgreementDocumentViewModel
@{
    var culture = System.Globalization.CultureInfo.GetCultureInfo(Model.LocaleCode);
    string Money(string currency, decimal value)
    {
        return $"{currency} {value.ToString("N2", culture)}";
    }
}

<h2>Ítems financiados</h2>
<table class="items">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Categoría</th>
            <th>Proveedor</th>
            <th class="amount">Precio unitario</th>
            <th class="amount">Total de la línea</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.CategoryName</td>
                <td>@item.SupplierName</td>
                <td class="amount">@Money(item.Currency, item.UnitPrice)</td>
                <td class="amount">@Money(item.Currency, item.LineTotal)</td>
            </tr>
        }
        @foreach (var t in Model.TotalsByCurrency)
        {
            <tr class="total-row">
                <td colspan="4">Total (@t.Currency)</td>
                <td class="amount">@Money(t.Currency, t.Amount)</td>
            </tr>
        }
    </tbody>
</table>
