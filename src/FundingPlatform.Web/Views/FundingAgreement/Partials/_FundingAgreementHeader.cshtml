@model FundingPlatform.Web.ViewModels.FundingAgreementDocumentViewModel
@{
    // Spec 012 / FR-017 / FR-018 / SC-005: PDF must render 1,234.56 and dd/MM/yyyy.
    // Raw es-CR CultureInfo defaults to '1 234 567,89' and 'd/M/yyyy'; we use the
    // format-overridden factory so the PDF and the UI share one rendering contract.
    var culture = FundingPlatform.Web.Localization.EsCrCultureFactory.Build();
}

<h1>Convenio de Financiamiento</h1>
<div class="document-reference">
    Referencia: <strong>@Model.AgreementReference</strong>
    &mdash;
    Generado: @Model.GeneratedAtUtc.ToString("dd/MM/yyyy HH:mm", culture) UTC
</div>

<div class="parties">
    <div class="party">
        <h2>Aportante</h2>
        <div><strong>@Model.Funder.LegalName</strong></div>
        <div>Cédula jurídica: @Model.Funder.TaxId</div>
        <div>@Model.Funder.Address</div>
        <div>Correo electrónico: @Model.Funder.ContactEmail</div>
        <div>Teléfono: @Model.Funder.ContactPhone</div>
    </div>
    <div class="party">
        <h2>Solicitante</h2>
        <div><strong>@Model.ApplicantLegalName</strong></div>
        <div>Cédula: @Model.ApplicantLegalId</div>
        <div>Correo electrónico: @Model.ApplicantEmail</div>
        @if (!string.IsNullOrWhiteSpace(Model.ApplicantPhone))
        {
            <div>Teléfono: @Model.ApplicantPhone</div>
        }
    </div>
</div>
