@model FundingPlatform.Web.ViewModels.FundingAgreementDocumentViewModel

<h2>Firmas</h2>
<div class="signature-blocks">
    <div class="signature">
        <div class="signature-line">
            <strong>Por el Aportante</strong>
        </div>
        <div>@Model.Funder.LegalName</div>
        <div>Cédula jurídica: @Model.Funder.TaxId</div>
    </div>
    <div class="signature">
        <div class="signature-line">
            <strong>Solicitante</strong>
        </div>
        <div>@Model.ApplicantLegalName</div>
        <div>Cédula: @Model.ApplicantLegalId</div>
    </div>
</div>
