@using FundingPlatform.Web.Localization
@model FundingPlatform.Web.ViewModels.FundingAgreementDetailsViewModel

@{
    ViewData["Title"] = $"Convenio de financiamiento — Solicitud N.º {Model.Panel.ApplicationId}";
    var preview = Model.Preview;
    var culture = EsCrCultureFactory.Build();
    string Money(string currency, decimal value) => $"{currency} {value.ToString("N2", culture)}";
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: $"Solicitud N.º {Model.Panel.ApplicationId} — Convenio de financiamiento",
        Breadcrumbs: new[]
        {
            new BreadcrumbItem("Inicio", Url.Action("Index", "Home")),
            new BreadcrumbItem("Convenio de financiamiento"),
        }))

<div class="card mb-4" data-testid="funding-agreement-preview">
    <div class="card-header">
        <strong>Resumen del convenio</strong>
        <span class="text-muted ms-2 small">Vista previa de los ítems aceptados que se incluirán en el documento.</span>
    </div>
    <div class="card-body">
        @if (preview is null)
        {
            <p class="text-muted mb-0" data-testid="funding-agreement-preview-unavailable">
                No se pudo cargar el detalle de la solicitud.
            </p>
        }
        else if (!Model.HasApplicantResponse)
        {
            <p class="text-muted mb-0" data-testid="funding-agreement-preview-awaiting-response">
                A la espera de la respuesta del solicitante. Una vez que el solicitante acepte o rechace los ítems aprobados, aquí aparecerá el detalle final del convenio.
            </p>
        }
        else if (preview.Items.Count == 0)
        {
            <p class="text-muted mb-0" data-testid="funding-agreement-preview-no-accepted-items">
                El solicitante no aceptó ningún ítem. No hay nada por incluir en el convenio.
            </p>
        }
        else
        {
            <dl class="row mb-3">
                <dt class="col-sm-3">Solicitante</dt>
                <dd class="col-sm-9" data-testid="funding-agreement-preview-applicant-name">@preview.ApplicantLegalName</dd>

                @if (!string.IsNullOrWhiteSpace(preview.ApplicantLegalId))
                {
                    <dt class="col-sm-3">Identificación</dt>
                    <dd class="col-sm-9">@preview.ApplicantLegalId</dd>
                }

                @if (!string.IsNullOrWhiteSpace(preview.ApplicantEmail))
                {
                    <dt class="col-sm-3">Correo electrónico</dt>
                    <dd class="col-sm-9">@preview.ApplicantEmail</dd>
                }

                @if (!string.IsNullOrWhiteSpace(preview.ApplicantPhone))
                {
                    <dt class="col-sm-3">Teléfono</dt>
                    <dd class="col-sm-9">@preview.ApplicantPhone</dd>
                }
            </dl>

            <div class="table-responsive">
                <table class="table table-vcenter card-table" data-testid="funding-agreement-preview-items">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Categoría</th>
                            <th>Proveedor</th>
                            <th class="text-end">Precio unitario</th>
                            <th class="text-end">Total de la línea</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in preview.Items)
                        {
                            <tr data-item-id="@item.ItemId">
                                <td>@item.ProductName</td>
                                <td>@item.CategoryName</td>
                                <td>@item.SupplierName</td>
                                <td class="text-end">@Money(item.Currency, item.UnitPrice)</td>
                                <td class="text-end">@Money(item.Currency, item.LineTotal)</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        @foreach (var t in preview.TotalsByCurrency)
                        {
                            <tr class="fw-bold" data-testid="funding-agreement-preview-total" data-currency="@t.Currency">
                                <td colspan="4" class="text-end">Total (@t.Currency)</td>
                                <td class="text-end">@Money(t.Currency, t.Amount)</td>
                            </tr>
                        }
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>

@await Html.PartialAsync("~/Views/Applications/_FundingAgreementPanel.cshtml", Model.Panel)

<div class="mt-3">
    <a class="btn btn-link" asp-controller="Home" asp-action="Index">&larr; Atrás</a>
</div>
