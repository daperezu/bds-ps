@model FundingPlatform.Web.ViewModels.SigningStagePanelViewModel

@{
    ViewData["Title"] = $"Funding Agreement — Application #{Model.ApplicationId}";
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: $"Application #{Model.ApplicationId} — Funding Agreement",
        Breadcrumbs: new[]
        {
            new BreadcrumbItem("Home", Url.Action("Index", "Home")),
            new BreadcrumbItem("Funding Agreement"),
        }))

@await Html.PartialAsync("~/Views/Applications/_FundingAgreementPanel.cshtml", Model)

<div class="mt-3">
    <a class="btn btn-link" asp-controller="Home" asp-action="Index">&larr; Back</a>
</div>
