@model FundingPlatform.Web.ViewModels.SigningStagePanelViewModel

@{
    ViewData["Title"] = $"Convenio de financiamiento — Solicitud N.º {Model.ApplicationId}";
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: $"Solicitud N.º {Model.ApplicationId} — Convenio de financiamiento",
        Breadcrumbs: new[]
        {
            new BreadcrumbItem("Inicio", Url.Action("Index", "Home")),
            new BreadcrumbItem("Convenio de financiamiento"),
        }))

@await Html.PartialAsync("~/Views/Applications/_FundingAgreementPanel.cshtml", Model)

<div class="mt-3">
    <a class="btn btn-link" asp-controller="Home" asp-action="Index">&larr; Atrás</a>
</div>
