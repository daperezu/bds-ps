@using FundingPlatform.Domain.Enums
@model FundingPlatform.Web.ViewModels.ApplicationViewModel

@{
    ViewData["Title"] = $"Edit Application #{Model.Id}";
    var state = Enum.Parse<ApplicationState>(Model.State);
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: $"Edit Application #{Model.Id}",
        Breadcrumbs: new[]
        {
            new BreadcrumbItem("My Applications", Url.Action("Index", "Application")),
            new BreadcrumbItem($"Application #{Model.Id}", Url.Action("Details", "Application", new { id = Model.Id })),
            new BreadcrumbItem("Edit"),
        }))

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <strong>Status:</strong>
                @await Html.PartialAsync("Components/_StatusPill", new StatusPillViewModel(state))
            </div>
            <div class="col-md-3">
                <strong>Created:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")
            </div>
            <div class="col-md-3">
                <strong>Updated:</strong> @Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm")
            </div>
            @if (Model.SubmittedAt.HasValue)
            {
                <div class="col-md-3">
                    <strong>Submitted:</strong> @Model.SubmittedAt.Value.ToString("yyyy-MM-dd HH:mm")
                </div>
            }
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Items</h4>
    <a asp-controller="Item" asp-action="Add" asp-route-appId="@Model.Id" class="btn btn-primary">
        <i class="ti ti-plus me-1"></i>Add Item
    </a>
</div>

@if (Model.Items.Count == 0)
{
    @await Html.PartialAsync("Components/_EmptyState",
        new EmptyStateViewModel(
            Headline: "No items added yet",
            Body: "Add at least one item to submit your application.",
            Icon: "ti ti-package",
            PrimaryAction: new ActionItem("Add Item", ActionClass.Primary,
                Url: Url.Action("Add", "Item", new { appId = Model.Id }),
                Icon: "ti ti-plus")))
}
else
{
    <div class="card mb-4">
        <div class="table-responsive">
            <table class="table card-table table-vcenter">
                <thead>
                    <tr>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Quotations</th>
                        <th>Impact</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.CategoryName</td>
                            <td>@item.QuotationCount</td>
                            <td>
                                @if (item.HasImpact)
                                {
                                    <span class="status status-green"><i class="ti ti-check"></i> Complete</span>
                                }
                                else
                                {
                                    <span class="status status-yellow"><i class="ti ti-clock"></i> Pending</span>
                                }
                            </td>
                            <td>
                                <a asp-controller="Item" asp-action="Edit" asp-route-appId="@Model.Id" asp-route-itemId="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form asp-controller="Item" asp-action="Delete" asp-route-appId="@Model.Id" asp-route-itemId="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to remove this item?')">Delete</button>
                                </form>
                            </td>
                        </tr>
                        @if (!string.IsNullOrEmpty(item.ReviewComment))
                        {
                            <tr>
                                <td colspan="5">
                                    <div class="text-secondary small ps-2 border-start border-3 border-info py-1">
                                        <strong>Reviewer Comment:</strong> @item.ReviewComment
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.Items.Count > 0)
{
    <div class="d-flex justify-content-end mb-3">
        <form asp-controller="Application" asp-action="Submit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">
                <i class="ti ti-send me-1"></i>Submit Application
            </button>
        </form>
    </div>
}

<div class="mt-3">
    <a asp-action="Index" asp-controller="Application" class="btn btn-link">&larr; Back to Applications</a>
</div>
