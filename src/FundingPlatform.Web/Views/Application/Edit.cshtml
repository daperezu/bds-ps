@using FundingPlatform.Domain.Enums
@model FundingPlatform.Web.ViewModels.ApplicationViewModel

@{
    ViewData["Title"] = $"Editar solicitud N.º {Model.Id}";
    var state = Enum.Parse<ApplicationState>(Model.State);
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: $"Editar solicitud N.º {Model.Id}",
        Breadcrumbs: new[]
        {
            new BreadcrumbItem("Mis solicitudes", Url.Action("Index", "Application")),
            new BreadcrumbItem($"Solicitud N.º {Model.Id}", Url.Action("Details", "Application", new { id = Model.Id })),
            new BreadcrumbItem("Editar"),
        }))

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <strong>Estado:</strong>
                @await Html.PartialAsync("Components/_StatusPill", new StatusPillViewModel(state))
            </div>
            <div class="col-md-3">
                <strong>Creada:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
            </div>
            <div class="col-md-3">
                <strong>Actualizada:</strong> @Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")
            </div>
            @if (Model.SubmittedAt.HasValue)
            {
                <div class="col-md-3">
                    <strong>Enviada:</strong> @Model.SubmittedAt.Value.ToString("dd/MM/yyyy HH:mm")
                </div>
            }
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Ítems</h4>
    <a asp-controller="Item" asp-action="Add" asp-route-appId="@Model.Id" class="btn btn-primary">
        <i class="ti ti-plus me-1"></i>Agregar ítem
    </a>
</div>

@if (Model.Items.Count == 0)
{
    @await Html.PartialAsync("Components/_EmptyState",
        new EmptyStateViewModel(
            Headline: "Aún no se han agregado ítems",
            Body: "Agregue al menos un ítem para enviar su solicitud.",
            Icon: "ti ti-package",
            PrimaryAction: new ActionItem("Agregar ítem", ActionClass.Primary,
                Url: Url.Action("Add", "Item", new { appId = Model.Id }),
                Icon: "ti ti-plus")))
}
else
{
    <div class="card mb-4">
        <div class="table-responsive">
            <table class="table card-table table-vcenter">
                <thead>
                    <tr>
                        <th>Nombre del producto</th>
                        <th>Categoría</th>
                        <th>Cotizaciones</th>
                        <th>Impacto</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.CategoryName</td>
                            <td>@item.QuotationCount</td>
                            <td>
                                @if (item.HasImpact)
                                {
                                    <span class="status status-green"><i class="ti ti-check"></i> Completo</span>
                                }
                                else
                                {
                                    <span class="status status-yellow"><i class="ti ti-clock"></i> Pendiente</span>
                                }
                            </td>
                            <td>
                                <a asp-controller="Item" asp-action="Edit" asp-route-appId="@Model.Id" asp-route-itemId="@item.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                                <form asp-controller="Item" asp-action="Delete" asp-route-appId="@Model.Id" asp-route-itemId="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Está seguro de que desea eliminar este ítem?')">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                        @if (!string.IsNullOrEmpty(item.ReviewComment))
                        {
                            <tr>
                                <td colspan="5">
                                    <div class="text-secondary small ps-2 border-start border-3 border-info py-1">
                                        <strong>Comentario del revisor:</strong> @item.ReviewComment
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.Items.Count > 0)
{
    <div class="d-flex justify-content-end mb-3">
        <form asp-controller="Application" asp-action="Submit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">
                <i class="ti ti-send me-1"></i>Enviar solicitud
            </button>
        </form>
    </div>
}

<div class="mt-3">
    <a asp-action="Index" asp-controller="Application" class="btn btn-link">&larr; Volver a solicitudes</a>
</div>
