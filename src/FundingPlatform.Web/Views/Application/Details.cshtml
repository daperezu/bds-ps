@using FundingPlatform.Domain.Enums
@model FundingPlatform.Web.ViewModels.ApplicationViewModel

@{
    ViewData["Title"] = $"Application #{Model.Id}";
    var state = Enum.Parse<ApplicationState>(Model.State);
    var headerActions = new List<ActionItem>();
    if (Model.State == nameof(ApplicationState.Draft))
    {
        headerActions.Add(new ActionItem("Add Item", ActionClass.Primary,
            Url: Url.Action("Add", "Item", new { appId = Model.Id }),
            Icon: "ti ti-plus"));
    }
    if (Model.State == nameof(ApplicationState.Resolved)
        || Model.State == nameof(ApplicationState.ResponseFinalized)
        || Model.State == nameof(ApplicationState.AppealOpen))
    {
        headerActions.Add(new ActionItem(
            Model.State == nameof(ApplicationState.Resolved) ? "Respond to Review" : "View Response",
            ActionClass.Primary,
            Url: Url.Action("Index", "ApplicantResponse", new { id = Model.Id }),
            Icon: "ti ti-message"));
    }
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: $"Application #{Model.Id}",
        PrimaryActions: headerActions))

@if (TempData["ValidationErrors"] is string validationErrorsJson)
{
    var errors = System.Text.Json.JsonSerializer.Deserialize<List<string>>(validationErrorsJson);
    if (errors is not null && errors.Count > 0)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Cannot submit application:</strong>
            <ul class="mb-0 mt-1">
                @foreach (var error in errors)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }
}

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <strong>Status:</strong>
                @await Html.PartialAsync("Components/_StatusPill", new StatusPillViewModel(state))
            </div>
            <div class="col-md-3">
                <strong>Created:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")
            </div>
            <div class="col-md-3">
                <strong>Updated:</strong> @Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm")
            </div>
            @if (Model.SubmittedAt.HasValue)
            {
                <div class="col-md-3">
                    <strong>Submitted:</strong> @Model.SubmittedAt.Value.ToString("yyyy-MM-dd HH:mm")
                </div>
            }
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Items</h4>
</div>

@if (Model.Items.Count == 0)
{
    @await Html.PartialAsync("Components/_EmptyState",
        new EmptyStateViewModel(
            Headline: "No items added yet",
            Body: Model.State == nameof(ApplicationState.Draft)
                ? "Add at least one item to submit your application."
                : "This application has no items.",
            Icon: "ti ti-package",
            PrimaryAction: Model.State == nameof(ApplicationState.Draft)
                ? new ActionItem("Add Item", ActionClass.Primary,
                    Url: Url.Action("Add", "Item", new { appId = Model.Id }),
                    Icon: "ti ti-plus")
                : null))
}
else
{
    <div class="card mb-4">
        <div class="table-responsive">
            <table class="table card-table table-vcenter">
                <thead>
                    <tr>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Quotations</th>
                        <th>Impact</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.CategoryName</td>
                            <td>@item.QuotationCount</td>
                            <td>
                                @if (item.HasImpact)
                                {
                                    <span class="status status-green"><i class="ti ti-check"></i> Complete</span>
                                }
                                else
                                {
                                    <span class="status status-yellow"><i class="ti ti-clock"></i> Pending</span>
                                }
                            </td>
                            <td>
                                @if (Model.State == nameof(ApplicationState.Draft))
                                {
                                    <a asp-controller="Supplier" asp-action="Add" asp-route-appId="@Model.Id" asp-route-itemId="@item.Id" class="btn btn-sm btn-outline-primary">Add Supplier</a>
                                    <a asp-controller="Item" asp-action="Edit" asp-route-appId="@Model.Id" asp-route-itemId="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <a asp-controller="Item" asp-action="Impact" asp-route-appId="@Model.Id" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Impact</a>
                                    <form asp-controller="Item" asp-action="Delete" asp-route-appId="@Model.Id" asp-route-itemId="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to remove this item?')">Delete</button>
                                    </form>
                                }
                            </td>
                        </tr>
                        @if (!string.IsNullOrEmpty(item.ReviewComment))
                        {
                            <tr>
                                <td colspan="5">
                                    <div class="text-secondary small ps-2 border-start border-3 border-info py-1">
                                        <strong>Reviewer Comment:</strong> @item.ReviewComment
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.State == nameof(ApplicationState.Draft))
{
    <div class="d-flex justify-content-end mb-3">
        <form asp-controller="Application" asp-action="Submit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">
                <i class="ti ti-send me-1"></i>Submit Application
            </button>
        </form>
    </div>
}

<div class="mt-3" id="funding-agreement-panel-container">
    <div data-async-panel-url="@Url.RouteUrl(new { controller = "FundingAgreement", action = "Panel", applicationId = Model.Id })">
        Loading funding agreement panel...
    </div>
</div>

<script>
(function () {
    var container = document.querySelector('#funding-agreement-panel-container > div[data-async-panel-url]');
    if (!container) return;
    var url = container.getAttribute('data-async-panel-url');
    fetch(url, { credentials: 'same-origin', headers: { 'Accept': 'text/html' } })
        .then(function (r) { return r.ok ? r.text() : ''; })
        .then(function (html) {
            var target = document.getElementById('funding-agreement-panel-container');
            if (target) target.innerHTML = html;
        })
        .catch(function () { /* non-disclosing: silently drop on error */ });
})();
</script>

<div class="mt-3">
    <a asp-action="Index" asp-controller="Application" class="btn btn-link">&larr; Back to Applications</a>
</div>
