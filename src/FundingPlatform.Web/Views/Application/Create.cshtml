@model FundingPlatform.Web.ViewModels.CreateApplicationViewModel

@{
    ViewData["Title"] = "Create Application";
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: "Create New Application",
        Subtitle: "Start a draft application — you can add items and submit it when ready.",
        Breadcrumbs: new[]
        {
            new BreadcrumbItem("My Applications", Url.Action("Index", "Application")),
            new BreadcrumbItem("Create New"),
        }))

<div class="card">
    <div class="card-body">
        <p class="text-secondary">Click the button below to create a new draft application. You can then add items and submit it when ready.</p>
        <form asp-action="Create" asp-controller="Application" method="post">
            @Html.AntiForgeryToken()
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="ti ti-plus me-1"></i>Create Draft Application
                </button>
                <a asp-action="Index" asp-controller="Application" class="btn btn-outline-secondary">
                    <i class="ti ti-arrow-left me-1"></i>Back
                </a>
            </div>
        </form>
    </div>
</div>
