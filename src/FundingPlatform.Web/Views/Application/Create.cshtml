@model FundingPlatform.Web.ViewModels.CreateApplicationViewModel

@{
    ViewData["Title"] = "Create Application";
}

<h2>Create New Application</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <p>Click the button below to create a new draft application. You can then add items and submit it when ready.</p>
                <form asp-action="Create" asp-controller="Application" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">Create Draft Application</button>
                </form>
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="Index" asp-controller="Application">Back to Applications</a>
        </div>
    </div>
</div>
