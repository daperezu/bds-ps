@model FundingPlatform.Web.ViewModels.ApplicationListViewModel

@{
    ViewData["Title"] = "My Applications";
}

<h2>My Applications</h2>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">Create New Application</a>
</div>

@if (Model.Applications.Count == 0)
{
    <div class="alert alert-info">
        You have no applications yet. Click "Create New Application" to get started.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Status</th>
                <th>Items</th>
                <th>Created</th>
                <th>Last Updated</th>
                <th>Submitted</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var app in Model.Applications)
            {
                <tr>
                    <td>@app.Id</td>
                    <td>
                        <span class="badge @(app.State == "Draft" ? "bg-secondary" : "bg-success")">
                            @app.State
                        </span>
                    </td>
                    <td>@app.ItemCount</td>
                    <td>@app.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@app.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        @if (app.SubmittedAt.HasValue)
                        {
                            @app.SubmittedAt.Value.ToString("yyyy-MM-dd HH:mm")
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@app.Id" class="btn btn-sm btn-info">View</a>
                        @if (app.State == "Draft")
                        {
                            <a asp-action="Edit" asp-route-id="@app.Id" class="btn btn-sm btn-warning">Edit</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
