@using FundingPlatform.Domain.Enums
@model FundingPlatform.Web.ViewModels.ApplicationListViewModel

@{
    ViewData["Title"] = "My Applications";
    var headerActions = new[]
    {
        new ActionItem("Create New Application", ActionClass.Primary,
            Url: Url.Action("Create"),
            Icon: "ti ti-plus"),
    };
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel("My Applications", PrimaryActions: headerActions))

@if (Model.Applications.Count == 0)
{
    @await Html.PartialAsync("Components/_EmptyState",
        new EmptyStateViewModel(
            Headline: "No applications yet",
            Body: "Create your first funding application to get started.",
            Icon: "ti ti-files",
            PrimaryAction: new ActionItem("Create your first application", ActionClass.Primary,
                Url: Url.Action("Create"),
                Icon: "ti ti-plus")))
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table card-table table-vcenter">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Status</th>
                        <th>Items</th>
                        <th>Created</th>
                        <th>Last Updated</th>
                        <th>Submitted</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model.Applications)
                    {
                        <tr>
                            <td>@app.Id</td>
                            <td>
                                @{
                                    var state = Enum.Parse<ApplicationState>(app.State);
                                }
                                @await Html.PartialAsync("Components/_StatusPill", new StatusPillViewModel(state))
                            </td>
                            <td>@app.ItemCount</td>
                            <td>@app.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@app.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (app.SubmittedAt.HasValue)
                                {
                                    @app.SubmittedAt.Value.ToString("yyyy-MM-dd HH:mm")
                                }
                                else
                                {
                                    <span class="text-secondary">-</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@app.Id" class="btn btn-sm btn-outline-primary">View</a>
                                @if (app.State == nameof(ApplicationState.Draft))
                                {
                                    <a asp-action="Edit" asp-route-id="@app.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
