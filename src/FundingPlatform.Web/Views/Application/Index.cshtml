@using FundingPlatform.Domain.Enums
@model FundingPlatform.Web.ViewModels.ApplicationListViewModel

@{
    ViewData["Title"] = "Mis solicitudes";
    var headerActions = new[]
    {
        new ActionItem("Crear nueva solicitud", ActionClass.Primary,
            Url: Url.Action("Create"),
            Icon: "ti ti-plus"),
    };
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel("Mis solicitudes", PrimaryActions: headerActions))

@if (Model.Applications.Count == 0)
{
    @await Html.PartialAsync("Components/_EmptyState",
        new EmptyStateViewModel(
            Headline: "Aún no tiene solicitudes",
            Body: "Cree su primera solicitud de financiamiento para empezar.",
            Icon: "ti ti-files",
            PrimaryAction: new ActionItem("Crear su primera solicitud", ActionClass.Primary,
                Url: Url.Action("Create"),
                Icon: "ti ti-plus")))
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table card-table table-vcenter">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Estado</th>
                        <th>Ítems</th>
                        <th>Creada</th>
                        <th>Última actualización</th>
                        <th>Enviada</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model.Applications)
                    {
                        <tr>
                            <td>@app.Id</td>
                            <td>
                                @{
                                    var state = Enum.Parse<ApplicationState>(app.State);
                                }
                                @await Html.PartialAsync("Components/_StatusPill", new StatusPillViewModel(state))
                            </td>
                            <td>@app.ItemCount</td>
                            <td>@app.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@app.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (app.SubmittedAt.HasValue)
                                {
                                    @app.SubmittedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                }
                                else
                                {
                                    <span class="text-secondary">-</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@app.Id" class="btn btn-sm btn-outline-primary">Ver</a>
                                @if (app.State == nameof(ApplicationState.Draft))
                                {
                                    <a asp-action="Edit" asp-route-id="@app.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
