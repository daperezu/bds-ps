@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="empty">
    <div class="empty-icon text-danger">
        <i class="ti ti-alert-circle" style="font-size: 3rem;"></i>
    </div>
    <p class="empty-title">An error occurred</p>
    <p class="empty-subtitle text-secondary">
        We hit a snag processing your request. Please try again.
    </p>
    @if (Model.ShowRequestId)
    {
        <p class="text-secondary"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }
    <div class="empty-action">
        <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
            <i class="ti ti-home me-1"></i> Back to Home
        </a>
    </div>
</div>
