@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="empty">
    <div class="empty-icon text-danger">
        <i class="ti ti-alert-circle icon-empty-state"></i>
    </div>
    <p class="empty-title">Ocurrió un error</p>
    <p class="empty-subtitle text-secondary">
        Tuvimos un inconveniente al procesar su solicitud. Inténtelo nuevamente.
    </p>
    @if (Model.ShowRequestId)
    {
        <p class="text-secondary"><strong>Identificador de solicitud:</strong> <code>@Model.RequestId</code></p>
    }
    <div class="empty-action">
        <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
            <i class="ti ti-home me-1"></i> Volver al inicio
        </a>
    </div>
</div>
