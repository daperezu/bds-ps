@model string
@{
    var activeTab = Model;
    var tabs = new (string Key, string Label, string Action)[]
    {
        ("Applications", "Solicitudes",       "Applications"),
        ("Applicants",   "Solicitantes",      "Applicants"),
        ("FundedItems",  "Ítems financiados", "FundedItems"),
        ("Aging",        "Antigüedad",        "Aging"),
    };
}
<ul class="nav nav-tabs" data-testid="report-subtabs">
    @foreach (var t in tabs)
    {
        var active = string.Equals(activeTab, t.Key, StringComparison.OrdinalIgnoreCase);
        <li class="nav-item">
            <a class="nav-link @(active ? "active" : null)"
               data-testid="report-subtab"
               data-tab="@t.Key"
               href="@Url.Action(t.Action, "AdminReports")">@t.Label</a>
        </li>
    }
</ul>
