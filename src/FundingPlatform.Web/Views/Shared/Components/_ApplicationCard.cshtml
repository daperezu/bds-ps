@using FundingPlatform.Application.DTOs
@model ApplicationCardDto
@{
    var primaryClass = Model.PrimaryAction.Style == ContextualActionStyle.Primary ? "btn btn-primary" : "btn btn-outline-secondary";
}
<article class="fl-app-card" data-testid="application-card" data-application-number="@Model.ApplicationNumber">
    <header class="d-flex justify-content-between align-items-start mb-3 flex-wrap fl-gap-2">
        <div>
            <div class="fl-app-card-mono fl-type-meta" data-testid="application-number">@Model.ApplicationNumber</div>
            <h3 class="fl-app-card-title" data-testid="application-card-title">@Model.ProjectName</h3>
        </div>
        <span class="fl-status-pill" data-tone="primary" data-testid="application-card-stage">@Model.CurrentStageLabel</span>
    </header>

    <div class="mb-3">
        @await Html.PartialAsync("Components/_ApplicationJourney", Model.JourneyMini)
    </div>

    <div class="d-flex justify-content-between align-items-center flex-wrap fl-gap-3">
        <div class="fl-app-card-meta" data-testid="application-card-meta">
            <span data-testid="days-in-state">@Model.DaysInCurrentState days in current state</span>
            <span class="mx-2">&middot;</span>
            <span data-testid="last-activity">Last activity @Model.LastActivity.LocalDateTime.ToString("MMM d, yyyy")</span>
        </div>
        <a class="@primaryClass" href="@Model.PrimaryAction.Href" data-testid="application-card-action">@Model.PrimaryAction.Label</a>
    </div>
</article>
