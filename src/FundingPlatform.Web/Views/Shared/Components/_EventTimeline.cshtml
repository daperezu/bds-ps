@model EventTimelineViewModel
@{
    var sorted = Model.Events.OrderByDescending(e => e.At).ToList();
    var scopeAttr = Model.Scope.ToString().ToLowerInvariant();
}
@if (sorted.Count == 0)
{
    if (Model.ShowEmptyMessage)
    {
        <div class="fl-text-secondary fl-type-meta" data-testid="event-timeline-empty" data-scope="@scopeAttr">Aún no hay eventos.</div>
    }
}
else
{
    <ul class="timeline list-unstyled" data-testid="event-timeline" data-scope="@scopeAttr">
        @foreach (var ev in sorted)
        {
            <li class="timeline-event mb-3 fl-pad-2" data-testid="timeline-event" data-at="@ev.At.ToString("o")">
                <div class="d-flex gap-2 align-items-start">
                    <div class="fl-text-secondary pt-1">
                        <i class="@(ev.Icon ?? "ti ti-point")"></i>
                    </div>
                    <div>
                        <div class="fw-bold fl-type-meta">@ev.Action</div>
                        <div class="fl-text-secondary fl-type-meta">@ev.Actor &middot; @ev.At.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</div>
                        @if (!string.IsNullOrWhiteSpace(ev.Detail))
                        {
                            <div class="mt-1 fl-type-body">@ev.Detail</div>
                        }
                    </div>
                </div>
            </li>
        }
    </ul>
}
