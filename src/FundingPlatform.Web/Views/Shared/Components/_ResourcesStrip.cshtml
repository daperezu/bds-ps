@using FundingPlatform.Application.Services
@inject IApplicantCopyProvider Copy
@{
    var cards = new[]
    {
        new { Title = Copy.ResourcesHowFundingWorks(), Body = "Cómo evaluamos las solicitudes, qué se financia y qué no.", Cta = "Leer la guía", Href = "/help/how-it-works" },
        new { Title = Copy.ResourcesSubmissionTips(),  Body = "Refuerce su solicitud con una descripción enfocada y cotizaciones precisas.", Cta = "Ver la lista de verificación", Href = "/help/submission-tips" },
        new { Title = Copy.ResourcesGetHelp(),         Body = "¿Atascado en algún paso? Le podemos ayudar.", Cta = "Contáctenos", Href = "/help/contact" },
    };
}
<section class="fl-strip mt-4" data-testid="resources-strip" aria-label="Recursos útiles">
    @foreach (var card in cards)
    {
        <article class="fl-strip-card">
            <h3 class="fl-strip-card-title">@card.Title</h3>
            <p class="fl-text-secondary fl-type-body">@card.Body</p>
            <a class="btn btn-link p-0" href="@card.Href">@card.Cta &rarr;</a>
        </article>
    }
</section>
