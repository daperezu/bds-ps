@model FormSectionViewModel
<div class="mb-3" data-testid="form-section" data-field="@Model.ForFieldName">
    <label class="form-label fl-type-meta">@Model.Label</label>
    @if (!string.IsNullOrWhiteSpace(Model.Hint))
    {
        <small class="form-hint d-block mb-1 fl-text-secondary fl-type-meta">@Model.Hint</small>
    }
    @RenderBody()
</div>
