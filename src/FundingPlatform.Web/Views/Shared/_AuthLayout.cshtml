<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Funding Platform</title>
    <link rel="stylesheet" href="~/lib/tabler/dist/css/tabler.min.css" />
    <link rel="stylesheet" href="~/lib/tabler/dist/css/tabler-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FundingPlatform.Web.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column">
    <div class="page page-center" data-testid="auth-shell">
        <div class="container container-tight py-4">
            <div class="text-center mb-4">
                <a href="@Url.Action("Index", "Home")" class="navbar-brand navbar-brand-autodark">Funding Platform</a>
            </div>
            <div class="card card-md">
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    <main role="main">
                        @RenderBody()
                    </main>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/tabler/dist/js/tabler.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
