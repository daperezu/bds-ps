@{
    var sidebarEntries = new List<SidebarEntry>
    {
        new("Inicio", Url.Action("Index", "Home") ?? "/", "ti ti-home", Array.Empty<string>()),
        new("Mis solicitudes", Url.Action("Index", "Application") ?? "/Application", "ti ti-files", new[] { "Applicant" }),
        new("Cola de revisión", Url.Action("Index", "Review") ?? "/Review", "ti ti-clipboard-check", new[] { "Reviewer", "Admin" }),
        new("Bandeja de firmas", Url.Action("SigningInbox", "Review") ?? "/Review/SigningInbox", "ti ti-pen", new[] { "Reviewer", "Admin" }),
        new("Administración", Url.Action("Index", "Admin") ?? "/Admin", "ti ti-settings", new[] { "Admin" }),
        new("Usuarios", "/Admin/Users", "ti ti-users", new[] { "Admin" }),
        new("Reportes", "/Admin/Reports", "ti ti-chart-line", new[] { "Admin" }),
    };

    bool IsEntryVisible(SidebarEntry entry)
    {
        if (User?.Identity?.IsAuthenticated != true) return false;
        if (entry.AllowedRoles.Length == 0) return true;
        // Suppress Applicant-only entries when the user is also a Reviewer or Admin —
        // every registered user implicitly holds the Applicant role on signup, so a
        // single role-array check would otherwise show "My Applications" to staff
        // (per contracts/README.md §3 "Reviewer ... does NOT see My Applications").
        if (entry.AllowedRoles.Length == 1
            && entry.AllowedRoles[0] == "Applicant"
            && (User.IsInRole("Reviewer") || User.IsInRole("Admin")))
        {
            return false;
        }
        return entry.AllowedRoles.Any(r => User.IsInRole(r));
    }

    string Slugify(string label) => label.ToLowerInvariant().Replace(' ', '-');

    var currentPath = Context.Request.Path.Value ?? "/";
    bool IsActive(string url)
    {
        if (string.Equals(url, "/", StringComparison.OrdinalIgnoreCase))
            return string.Equals(currentPath, "/", StringComparison.OrdinalIgnoreCase);
        return currentPath.StartsWith(url, StringComparison.OrdinalIgnoreCase);
    }
}
<!DOCTYPE html>
<html lang="es-CR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Capital Semilla</title>
    <link rel="icon" type="image/svg+xml" href="~/lib/brand/favicons/favicon.svg" />
    @* tokens.css MUST load BEFORE Tabler so the --tblr-* bridge in tokens.css applies (FR-008). *@
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/tabler/dist/css/tabler.min.css" />
    <link rel="stylesheet" href="~/lib/tabler/dist/css/tabler-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="page">
        @if (User?.Identity?.IsAuthenticated == true)
        {
            <aside class="navbar navbar-vertical navbar-expand-lg navbar-dark" data-bs-theme="dark" data-testid="sidebar">
                <div class="container-fluid">
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebar-menu" aria-controls="sidebar-menu" aria-expanded="false" aria-label="Mostrar u ocultar la navegación">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <h1 class="navbar-brand navbar-brand-autodark">
                        <a href="@Url.Action("Index", "Home")" class="fl-font-display">Capital Semilla</a>
                    </h1>
                    <div class="collapse navbar-collapse" id="sidebar-menu">
                        <ul class="navbar-nav pt-lg-3">
                            @foreach (var entry in sidebarEntries.Where(IsEntryVisible))
                            {
                                var slug = Slugify(entry.Label);
                                var active = IsActive(entry.Url) ? " active" : string.Empty;
                                <li class="nav-item@active">
                                    <a class="nav-link" href="@entry.Url" data-testid="sidebar-entry-@slug">
                                        <span class="nav-link-icon d-md-none d-lg-inline-block"><i class="@entry.Icon"></i></span>
                                        <span class="nav-link-title">@entry.Label</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </aside>
        }
        <header class="navbar navbar-expand-md d-print-none" data-testid="topbar">
            <div class="container-xl">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-menu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="page-title mb-0 fs-3" data-testid="page-title">@ViewData["Title"]</div>
                <div class="navbar-nav flex-row order-md-last">
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <div class="nav-item d-flex align-items-center px-2">
                            <span class="text-secondary">@User.Identity.Name</span>
                        </div>
                        <div class="nav-item d-flex align-items-center">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-link nav-link">
                                    <i class="ti ti-logout me-1"></i> Cerrar sesión
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Iniciar sesión</a>
                        </div>
                        <div class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">Crear cuenta</a>
                        </div>
                    }
                </div>
            </div>
        </header>
        <div class="page-wrapper">
            <div class="container-xl py-3" data-testid="breadcrumbs">
                @await RenderSectionAsync("Breadcrumbs", required: false)
            </div>
            <div class="page-body">
                <div class="container-xl">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                        </div>
                    }
                    <main role="main">
                        @RenderBody()
                    </main>
                </div>
            </div>
            <footer class="footer footer-transparent d-print-none">
                <div class="container-xl">
                    <div class="text-secondary text-center py-3 fl-type-meta">&copy; 2026 Capital Semilla &middot; diseñado para emprendedores</div>
                </div>
            </footer>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/tabler/dist/js/tabler.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/canvas-confetti/canvas-confetti.min.js" defer></script>
    <script src="~/js/motion.js" asp-append-version="true" defer></script>
    <script src="~/js/facelift-init.js" asp-append-version="true" defer></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
