@using FundingPlatform.Domain.Enums
@model IReadOnlyList<FundingPlatform.Web.ViewModels.SigningInboxRowViewModel>

@{
    ViewData["Title"] = "Signing Inbox";
    ViewData["ActiveTab"] = "Signing";
    var page = (int)(ViewData["SigningInbox.Page"] ?? 1);
    var pageSize = (int)(ViewData["SigningInbox.PageSize"] ?? 25);
    var totalCount = (int)(ViewData["SigningInbox.TotalCount"] ?? 0);
    var totalPages = (int)Math.Ceiling(totalCount / (double)pageSize);
}

@await Html.PartialAsync("_ReviewTabs")

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: "Signing Inbox",
        Subtitle: $"{totalCount} pending signed agreement(s) awaiting review"))

@if (Model.Count == 0)
{
    <div data-testid="signing-inbox-empty">
        @await Html.PartialAsync("Components/_EmptyState",
            new EmptyStateViewModel(
                Headline: "No pending signed uploads",
                Body: "Signed agreements awaiting reviewer approval will appear here.",
                Icon: "ti ti-pen"))
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table card-table table-vcenter table-sm" data-testid="signing-inbox-table">
                <thead>
                    <tr>
                        <th>Application</th>
                        <th>Applicant</th>
                        <th>Uploaded</th>
                        <th>Version match</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model)
                    {
                        <tr data-testid="signing-inbox-row" data-application-id="@row.ApplicationId">
                            <td>#@row.ApplicationId</td>
                            <td>@row.ApplicantDisplayName</td>
                            <td>@row.UploadedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                            <td>
                                @if (row.VersionMatchesCurrent)
                                {
                                    <span class="status status-green"><i class="ti ti-check"></i> Matches current</span>
                                }
                                else
                                {
                                    <span class="status status-yellow"><i class="ti ti-alert-triangle"></i> Stale (v@row.GeneratedVersionAtUpload)</span>
                                }
                            </td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary"
                                   href="@Url.RouteUrl(new { controller = "FundingAgreement", action = "Details", applicationId = row.ApplicationId })">
                                    Open
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination">
                @for (var p = 1; p <= totalPages; p++)
                {
                    var classes = p == page ? "page-item active" : "page-item";
                    <li class="@classes">
                        <a class="page-link" href="@Url.Action("SigningInbox", "Review", new { page = p, pageSize })">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
