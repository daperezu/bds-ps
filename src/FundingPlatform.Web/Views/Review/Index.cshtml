@using FundingPlatform.Domain.Enums
@model FundingPlatform.Web.ViewModels.ReviewQueueViewModel

@{
    ViewData["Title"] = "Cola de revisión";
    ViewData["ActiveTab"] = "Initial";
}

@await Html.PartialAsync("_ReviewTabs")

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: "Cola de revisión",
        Subtitle: $"{Model.TotalCount} solicitud(es) enviada(s)"))

@if (Model.Applications.Count == 0)
{
    @await Html.PartialAsync("Components/_EmptyState",
        new EmptyStateViewModel(
            Headline: "No hay solicitudes pendientes de revisión",
            Body: "Las solicitudes enviadas aparecerán aquí cuando los solicitantes terminen sus borradores.",
            Icon: "ti ti-clipboard-check"))
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table card-table table-vcenter table-sm review-queue">
                <thead>
                    <tr>
                        <th>Solicitud</th>
                        <th>Solicitante</th>
                        <th>Puntaje de desempeño</th>
                        <th>Enviada</th>
                        <th>Ítems</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model.Applications)
                    {
                        <tr>
                            <td>N.º @app.ApplicationId</td>
                            <td>@app.ApplicantName</td>
                            <td>
                                @if (app.ApplicantPerformanceScore.HasValue)
                                {
                                    @app.ApplicantPerformanceScore.Value.ToString("F2")
                                }
                                else
                                {
                                    <span class="text-secondary">N/D</span>
                                }
                            </td>
                            <td>@app.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@app.ItemCount</td>
                            <td>
                                <a asp-action="Review" asp-route-id="@app.ApplicationId" class="btn btn-sm btn-primary">Revisar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="pagination mt-3" aria-label="Paginación de la cola de revisión">
            <ul class="pagination">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)">Anterior</a>
                    </li>
                }
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)">Siguiente</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
