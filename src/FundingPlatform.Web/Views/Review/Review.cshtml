@using FundingPlatform.Domain.Enums
@model FundingPlatform.Web.ViewModels.ReviewApplicationViewModel

@{
    ViewData["Title"] = $"Revisar solicitud N.º {Model.ApplicationId}";
    var appState = Enum.Parse<ApplicationState>(Model.State);
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: $"Revisar solicitud N.º {Model.ApplicationId}",
        Subtitle: Model.ApplicantName))

@if (Model.UnresolvedItemWarnings is not null)
{
    <div class="alert alert-warning unresolved-warning" role="alert">
        <strong>Advertencia:</strong> Los siguientes ítems están sin resolver:
        <ul class="mb-2">
            @foreach (var item in Model.UnresolvedItemWarnings)
            {
                <li>@item</li>
            }
        </ul>
        <p class="mb-2">Confirmar rechazará implícitamente todos los ítems sin resolver.</p>
        <form asp-action="Finalize" asp-route-id="@Model.ApplicationId" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="force" value="true" />
            <button type="submit" id="forceFinalizationConfirm" class="btn btn-danger btn-sm me-2">Confirmar finalización</button>
        </form>
        <a asp-action="Review" asp-route-id="@Model.ApplicationId" class="btn btn-secondary btn-sm">Cancelar</a>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <strong>Solicitante:</strong>
                <span class="applicant-name">@Model.ApplicantName</span>
            </div>
            <div class="col-md-3">
                <strong>Puntaje de desempeño:</strong>
                <span class="performance-score">
                    @if (Model.ApplicantPerformanceScore.HasValue)
                    {
                        @Model.ApplicantPerformanceScore.Value.ToString("F2")
                    }
                    else
                    {
                        <span class="text-secondary">N/D</span>
                    }
                </span>
            </div>
            <div class="col-md-3">
                <strong>Estado:</strong>
                <span class="application-state">
                    @await Html.PartialAsync("Components/_StatusPill", new StatusPillViewModel(appState))
                </span>
            </div>
            @if (Model.SubmittedAt.HasValue)
            {
                <div class="col-md-3">
                    <strong>Enviada:</strong> @Model.SubmittedAt.Value.ToString("dd/MM/yyyy HH:mm")
                </div>
            }
        </div>
    </div>
</div>

<h4>Ítems (@Model.Items.Count)</h4>

@foreach (var item in Model.Items)
{
    var itemReviewStatus = Enum.Parse<ItemReviewStatus>(item.ReviewStatus);
    <div class="card mb-3 review-item" data-item-id="@item.ItemId">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <strong>@item.ProductName</strong>
                <span class="text-secondary ms-2">(@item.CategoryName)</span>
            </div>
            <span class="review-status-badge">
                @await Html.PartialAsync("Components/_StatusPill", new StatusPillViewModel(itemReviewStatus))
            </span>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <strong>Especificaciones técnicas:</strong>
                <p class="mb-0">@item.TechnicalSpecifications</p>
            </div>

            @if (item.ImpactTemplateName is not null)
            {
                <div class="mb-3">
                    <strong>Evaluación de impacto:</strong> @item.ImpactTemplateName
                    @if (item.ImpactParameters.Count > 0)
                    {
                        <table class="table table-sm mt-1">
                            <thead><tr><th>Parámetro</th><th>Valor</th></tr></thead>
                            <tbody>
                                @foreach (var param in item.ImpactParameters)
                                {
                                    <tr><td>@param.DisplayLabel</td><td>@param.Value</td></tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }

            <div class="mb-3">
                <strong>Cotizaciones:</strong>
                <table class="table table-sm mt-1">
                    <thead>
                        <tr>
                            <th>Proveedor</th>
                            <th>Cédula jurídica</th>
                            <th>Puntaje</th>
                            <th>Desglose</th>
                            <th>Precio</th>
                            <th>Vigente hasta</th>
                            <th>Documento</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var q in item.Quotations)
                        {
                            <tr class="quotation-row @(q.IsRecommended ? "table-success" : "")">
                                <td>@q.SupplierName</td>
                                <td>@q.SupplierLegalId</td>
                                <td><span class="supplier-score">@q.Score/5</span></td>
                                <td>
                                    <span class="score-breakdown">
                                        @if (q.ScoreCCSS) { <span class="status status-blue" title="CCSS">CCSS</span> }
                                        @if (q.ScoreHacienda) { <span class="status status-blue" title="Hacienda">Hac</span> }
                                        @if (q.ScoreSICOP) { <span class="status status-blue" title="SICOP">SICOP</span> }
                                        @if (q.ScoreElectronicInvoice) { <span class="status status-blue" title="Factura electrónica">Fact-E</span> }
                                        @if (q.ScoreLowestPrice) { <span class="status status-blue" title="Menor precio">Precio</span> }
                                    </span>
                                </td>
                                <td>@q.Price.ToString("C")</td>
                                <td>@q.ValidUntil.ToString("dd/MM/yyyy")</td>
                                <td>@q.DocumentFileName</td>
                                <td>
                                    @if (q.IsRecommended)
                                    {
                                        <span class="recommended-badge status status-green"><i class="ti ti-star"></i> Recomendada</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (item.ReviewComment is not null)
            {
                <div class="mb-3">
                    <strong>Comentario de revisión:</strong>
                    <p class="mb-0 fst-italic">@item.ReviewComment</p>
                </div>
            }

            @if (item.IsNotTechnicallyEquivalent)
            {
                <div class="alert alert-warning py-1 mb-3">
                    <strong>Marcado:</strong> Las cotizaciones no son técnicamente equivalentes.
                </div>
            }

            @if (Model.State == nameof(ApplicationState.UnderReview))
            {
                <hr />
                <div class="row">
                    <div class="col-md-6">
                        <h6>Equivalencia técnica</h6>
                        <form asp-action="FlagEquivalence" asp-route-id="@Model.ApplicationId" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ItemId" value="@item.ItemId" />
                            @if (item.IsNotTechnicallyEquivalent)
                            {
                                <input type="hidden" name="IsNotEquivalent" value="false" />
                                <button type="submit" data-item-id="@item.ItemId" class="btn btn-sm btn-outline-success submit-equivalence">
                                    Eliminar marca de no equivalencia
                                </button>
                            }
                            else
                            {
                                <input type="hidden" name="IsNotEquivalent" value="true" />
                                <button type="submit" data-item-id="@item.ItemId" class="btn btn-sm btn-outline-warning submit-equivalence">
                                    Marcar como no técnicamente equivalente
                                </button>
                            }
                        </form>
                    </div>

                    @if (!item.IsNotTechnicallyEquivalent)
                    {
                        <div class="col-md-6">
                            <h6>Decisión del ítem</h6>
                            <form asp-action="ReviewItem" asp-route-id="@Model.ApplicationId" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ItemId" value="@item.ItemId" />

                                <div class="mb-2">
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input decision-radio" type="radio" name="Decision" value="Approve"
                                               id="approve_@item.ItemId" data-item-id="@item.ItemId"
                                               @(item.ReviewStatus == "Approved" ? "checked" : "")>
                                        <label class="form-check-label" for="approve_@item.ItemId">Aprobar</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input decision-radio" type="radio" name="Decision" value="Reject"
                                               id="reject_@item.ItemId" data-item-id="@item.ItemId"
                                               @(item.ReviewStatus == "Rejected" ? "checked" : "")>
                                        <label class="form-check-label" for="reject_@item.ItemId">Rechazar</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input decision-radio" type="radio" name="Decision" value="RequestMoreInfo"
                                               id="moreinfo_@item.ItemId" data-item-id="@item.ItemId"
                                               @(item.ReviewStatus == "NeedsInfo" ? "checked" : "")>
                                        <label class="form-check-label" for="moreinfo_@item.ItemId">Solicitar más información</label>
                                    </div>
                                </div>

                                <div class="mb-2 supplier-select-wrapper @(item.ReviewStatus == "Approved" ? "" : "d-none")" id="supplierSelect_@item.ItemId">
                                    <label class="form-label">Seleccionar proveedor:</label>
                                    <select name="SelectedSupplierId" class="form-select form-select-sm">
                                        <option value="">-- Seleccione un proveedor --</option>
                                        @foreach (var q in item.Quotations)
                                        {
                                            var isSelected = item.SelectedSupplierId.HasValue
                                                ? item.SelectedSupplierId == q.SupplierId
                                                : q.IsPreSelected;
                                            var label = $"{q.SupplierName} - {q.Price:C} ({q.Score}/5)";
                                            if (q.IsRecommended)
                                            {
                                                label += " (Recomendada)";
                                            }
                                            if (isSelected)
                                            {
                                                <option value="@q.SupplierId" selected>@label</option>
                                            }
                                            else
                                            {
                                                <option value="@q.SupplierId">@label</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="mb-2">
                                    <label class="form-label">Comentario (opcional):</label>
                                    <textarea name="Comment" class="form-control form-control-sm" rows="2"
                                              maxlength="2000">@item.ReviewComment</textarea>
                                </div>

                                <button type="submit" data-item-id="@item.ItemId" class="btn btn-sm btn-primary submit-decision">
                                    Guardar decisión
                                </button>
                            </form>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@if (Model.State == nameof(ApplicationState.UnderReview))
{
    <div class="mt-4 d-flex gap-2">
        <form asp-action="SendBack" asp-route-id="@Model.ApplicationId" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning" onclick="return confirm('¿Devolver esta solicitud al solicitante?')">
                <i class="ti ti-arrow-back-up me-1"></i>Devolver
            </button>
        </form>

        <form asp-action="Finalize" asp-route-id="@Model.ApplicationId" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">
                <i class="ti ti-check me-1"></i>Finalizar revisión
            </button>
        </form>
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-link">&larr; Volver a la cola de revisión</a>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.decision-radio').forEach(radio => {
            radio.addEventListener('change', function() {
                const itemId = this.dataset.itemId;
                const wrapper = document.getElementById('supplierSelect_' + itemId);
                if (wrapper) {
                    wrapper.classList.toggle('d-none', this.value !== 'Approve');
                }
            });
        });
    </script>
}
