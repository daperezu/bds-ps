@model FundingPlatform.Web.ViewModels.GenerateAgreementQueueViewModel

@{
    ViewData["Title"] = "Generar convenio";
    ViewData["ActiveTab"] = "Generate";
}

@await Html.PartialAsync("_ReviewTabs")

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: "Generar convenio",
        Subtitle: "Solicitudes pendientes de generación del convenio de financiamiento."))

@if (Model.Applications.Count == 0)
{
    <div data-testid="generate-agreement-empty">
        @await Html.PartialAsync("Components/_EmptyState",
            new EmptyStateViewModel(
                Headline: "No hay solicitudes pendientes de convenio",
                Body: "Las solicitudes pendientes de generación del convenio de financiamiento aparecerán aquí cuando sus revisiones se finalicen.",
                Icon: "ti ti-file-text"))
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table card-table table-vcenter table-sm" data-testid="generate-agreement-table">
                <thead>
                    <tr>
                        <th>Solicitud</th>
                        <th>Solicitante</th>
                        <th>Respuesta finalizada el</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Applications)
                    {
                        <tr data-testid="generate-agreement-row" data-application-id="@row.ApplicationId">
                            <td>N.º @row.ApplicationId</td>
                            <td>@row.ApplicantDisplayName</td>
                            <td>@row.ResponseFinalizedAtUtc.ToString("dd/MM/yyyy HH:mm") UTC</td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary"
                                   href="@Url.RouteUrl(new { controller = "FundingAgreement", action = "Details", applicationId = row.ApplicationId })">
                                    <i class="ti ti-arrow-right me-1"></i>Abrir
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination">
                @for (var p = 1; p <= Model.TotalPages; p++)
                {
                    var classes = p == Model.CurrentPage ? "page-item active" : "page-item";
                    <li class="@classes">
                        <a class="page-link" href="@Url.Action("GenerateAgreement", "Review", new { page = p })">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
