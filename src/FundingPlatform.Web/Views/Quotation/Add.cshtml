@model FundingPlatform.Web.ViewModels.AddQuotationViewModel

@{
    ViewData["Title"] = "Agregar cotización";
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: "Agregar cotización",
        Subtitle: $"Para el proveedor: {Model.SupplierName}",
        Breadcrumbs: new[]
        {
            new BreadcrumbItem("Mis solicitudes", Url.Action("Index", "Application")),
            new BreadcrumbItem($"Solicitud N.º {Model.ApplicationId}", Url.Action("Details", "Application", new { id = Model.ApplicationId })),
            new BreadcrumbItem("Agregar cotización"),
        }))

<div class="card">
    <div class="card-body">
        <form asp-controller="Quotation" asp-action="Add" asp-route-appId="@Model.ApplicationId" asp-route-itemId="@Model.ItemId" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger"></div>

            <input type="hidden" asp-for="ApplicationId" />
            <input type="hidden" asp-for="ItemId" />
            <input type="hidden" asp-for="SupplierId" />
            <input type="hidden" asp-for="SupplierName" />

            <div class="mb-3">
                <label class="form-label">Proveedor</label>
                <input type="text" class="form-control" value="@Model.SupplierName" readonly />
            </div>

            <div class="mb-3" data-testid="form-section" data-field="Price">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" />
                <span asp-validation-for="Price" class="invalid-feedback d-block"></span>
            </div>

            <div class="mb-3" data-testid="form-section" data-field="Currency">
                <label asp-for="Currency" class="form-label"></label>
                <input asp-for="Currency" class="form-control" maxlength="3" />
                <small class="form-hint">ISO 4217 (p. ej., CRC, USD)</small>
                <span asp-validation-for="Currency" class="invalid-feedback d-block"></span>
            </div>

            <div class="mb-3" data-testid="form-section" data-field="ValidUntil">
                <label asp-for="ValidUntil" class="form-label"></label>
                <input asp-for="ValidUntil" class="form-control" type="date" />
                <span asp-validation-for="ValidUntil" class="invalid-feedback d-block"></span>
            </div>

            <div class="mb-3" data-testid="form-section" data-field="QuotationFile">
                <label asp-for="QuotationFile" class="form-label"></label>
                <input asp-for="QuotationFile" class="form-control" type="file" />
                <span asp-validation-for="QuotationFile" class="invalid-feedback d-block"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Agregar cotización</button>
                <a asp-controller="Application" asp-action="Details" asp-route-id="@Model.ApplicationId" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
