@using FundingPlatform.Domain.Enums
@model FundingPlatform.Web.ViewModels.ApplicantResponseViewModel

@{
    ViewData["Title"] = $"Application #{Model.ApplicationId} — Applicant Response";
}

<div class="applicant-response-header">
    @await Html.PartialAsync("Components/_PageHeader",
        new PageHeaderViewModel(
            Title: $"Application #{Model.ApplicationId} — Applicant Response",
            Breadcrumbs: new[]
            {
                new BreadcrumbItem("My Applications", Url.Action("Index", "Application")),
                new BreadcrumbItem($"Application #{Model.ApplicationId}", Url.Action("Details", "Application", new { id = Model.ApplicationId })),
                new BreadcrumbItem("Response"),
            }))
</div>

<div class="card mb-3">
    <div class="card-body">
        <strong>State:</strong>
        <span class="application-state">
            @await Html.PartialAsync("Components/_StatusPill", new StatusPillViewModel(Model.State))
        </span>
        @if (Model.SubmittedAt is not null)
        {
            <span class="ms-3 submitted-at"><strong>Response submitted:</strong> @Model.SubmittedAt.Value.ToString("yyyy-MM-dd HH:mm")</span>
        }
    </div>
</div>

@{
    var isReadOnly = Model.IsSubmitted || Model.State == ApplicationState.AppealOpen;
}

@if (Model.State == ApplicationState.AgreementExecuted)
{
    <div class="alert alert-success" data-testid="signing-banner-executed">
        Your funding agreement has been executed.
    </div>
}
else if (Model.State == ApplicationState.ResponseFinalized && Model.HasFundingAgreement)
{
    <div class="alert alert-info" data-testid="signing-banner-ready">
        Your funding agreement is ready to sign below.
    </div>
}

<form method="post" asp-action="Submit" asp-route-id="@Model.ApplicationId" id="applicantResponseForm">
    @Html.AntiForgeryToken()
    <div class="card">
        <div class="table-responsive">
            <table class="table card-table table-vcenter response-items">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Reviewer Decision</th>
                        <th>Supplier</th>
                        <th>Amount</th>
                        <th>Comment</th>
                        <th>Your Decision</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr class="response-item" data-item-id="@item.ItemId">
                            <td class="item-name">@item.ProductName</td>
                            <td>
                                <span class="review-status review-status-@item.ReviewStatus.ToString().ToLowerInvariant()">
                                    @await Html.PartialAsync("Components/_StatusPill", new StatusPillViewModel(item.ReviewStatus))
                                </span>
                            </td>
                            <td class="supplier-name">@(item.SelectedSupplierName ?? "—")</td>
                            <td class="amount">@(item.Amount.HasValue ? item.Amount.Value.ToString("C") : "—")</td>
                            <td class="review-comment">@(item.ReviewComment ?? "—")</td>
                            <td>
                                @if (isReadOnly)
                                {
                                    if (item.Decision.HasValue)
                                    {
                                        var color = item.Decision == ItemResponseDecision.Accept ? "green" : "red";
                                        var icon = item.Decision == ItemResponseDecision.Accept ? "ti ti-check" : "ti ti-x";
                                        <span class="decision-display status status-@color"><i class="@icon"></i> @item.Decision</span>
                                    }
                                    else
                                    {
                                        <span class="text-secondary">—</span>
                                    }
                                }
                                else
                                {
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input decision-accept"
                                               type="radio"
                                               name="decisions[@item.ItemId]"
                                               value="@((int)ItemResponseDecision.Accept)"
                                               id="accept-@item.ItemId"
                                               @(item.Decision == ItemResponseDecision.Accept ? "checked" : "")
                                               required>
                                        <label class="form-check-label" for="accept-@item.ItemId">Accept</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input decision-reject"
                                               type="radio"
                                               name="decisions[@item.ItemId]"
                                               value="@((int)ItemResponseDecision.Reject)"
                                               id="reject-@item.ItemId"
                                               @(item.Decision == ItemResponseDecision.Reject ? "checked" : "")
                                               required>
                                        <label class="form-check-label" for="reject-@item.ItemId">Reject</label>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (!isReadOnly)
    {
        <div class="mt-3 d-flex justify-content-end">
            <button type="submit" class="btn btn-primary submit-response" id="submitResponseButton" disabled>
                <i class="ti ti-send me-1"></i>Submit Response
            </button>
        </div>
    }
</form>

@if (Model.CanOpenAppeal)
{
    <div class="mt-4">
        <form method="post" asp-action="OpenAppeal" asp-route-id="@Model.ApplicationId">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning open-appeal-button">
                <i class="ti ti-alert-triangle me-1"></i>Open Appeal
            </button>
        </form>
    </div>
}

@if (Model.HasOpenAppeal)
{
    <div class="alert alert-warning mt-3 appeal-frozen-banner">
        An appeal is currently open. The application is frozen until the appeal is resolved.
        <a asp-action="Appeal" asp-route-id="@Model.ApplicationId" class="alert-link">View dispute thread</a>
    </div>
}

<div class="mt-3" id="funding-agreement-panel-container">
    <div data-async-panel-url="@Url.RouteUrl(new { controller = "FundingAgreement", action = "Panel", applicationId = Model.ApplicationId })">
        Loading funding agreement panel...
    </div>
</div>

<script>
(function () {
    var container = document.querySelector('#funding-agreement-panel-container > div[data-async-panel-url]');
    if (!container) return;
    var url = container.getAttribute('data-async-panel-url');
    fetch(url, { credentials: 'same-origin', headers: { 'Accept': 'text/html' } })
        .then(function (r) { return r.ok ? r.text() : ''; })
        .then(function (html) {
            var target = document.getElementById('funding-agreement-panel-container');
            if (target) target.innerHTML = html;
        })
        .catch(function () { /* non-disclosing: silently drop on error */ });
})();
</script>

@section Scripts {
    <script>
        (function () {
            var form = document.getElementById('applicantResponseForm');
            if (!form) return;
            var submitBtn = document.getElementById('submitResponseButton');
            if (!submitBtn) return;

            function refreshSubmitButton() {
                var rows = form.querySelectorAll('tr.response-item');
                var allAnswered = true;
                rows.forEach(function (row) {
                    var anyChecked = row.querySelector('input[type=radio]:checked');
                    if (!anyChecked) allAnswered = false;
                });
                submitBtn.disabled = !allAnswered;
            }

            form.addEventListener('change', refreshSubmitButton);
            refreshSubmitButton();
        })();
    </script>
}
