@model FundingPlatform.Web.ViewModels.AddItemViewModel

@{
    ViewData["Title"] = "Agregar ítem";
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: "Agregar ítem",
        Breadcrumbs: new[]
        {
            new BreadcrumbItem("Mis solicitudes", Url.Action("Index", "Application")),
            new BreadcrumbItem($"Solicitud N.º {Model.ApplicationId}", Url.Action("Details", "Application", new { id = Model.ApplicationId })),
            new BreadcrumbItem("Agregar ítem"),
        }))

<div class="card">
    <div class="card-body">
        <form asp-controller="Item" asp-action="Add" asp-route-appId="@Model.ApplicationId" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger"></div>

            <input type="hidden" asp-for="ApplicationId" />

            <div class="mb-3" data-testid="form-section" data-field="ProductName">
                <label asp-for="ProductName" class="form-label"></label>
                <input asp-for="ProductName" class="form-control" />
                <span asp-validation-for="ProductName" class="invalid-feedback d-block"></span>
            </div>

            <div class="mb-3" data-testid="form-section" data-field="CategoryId">
                <label asp-for="CategoryId" class="form-label"></label>
                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                    <option value="">-- Seleccione una categoría --</option>
                </select>
                <span asp-validation-for="CategoryId" class="invalid-feedback d-block"></span>
            </div>

            <div class="mb-3" data-testid="form-section" data-field="TechnicalSpecifications">
                <label asp-for="TechnicalSpecifications" class="form-label"></label>
                <textarea asp-for="TechnicalSpecifications" class="form-control" rows="5"></textarea>
                <span asp-validation-for="TechnicalSpecifications" class="invalid-feedback d-block"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Agregar ítem</button>
                <a asp-controller="Application" asp-action="Details" asp-route-id="@Model.ApplicationId" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
