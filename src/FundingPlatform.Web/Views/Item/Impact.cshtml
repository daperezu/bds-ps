@model FundingPlatform.Web.ViewModels.ImpactViewModel

@{
    ViewData["Title"] = $"Impact Assessment - {Model.ItemProductName}";
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: "Impact Assessment",
        Subtitle: $"Item: {Model.ItemProductName}",
        Breadcrumbs: new[]
        {
            new BreadcrumbItem("My Applications", Url.Action("Index", "Application")),
            new BreadcrumbItem($"Application #{Model.ApplicationId}", Url.Action("Details", "Application", new { id = Model.ApplicationId })),
            new BreadcrumbItem("Impact"),
        }))

<div class="row">
    <div class="col-md-8">
        <form asp-controller="Item" asp-action="Impact" asp-route-appId="@Model.ApplicationId" asp-route-id="@Model.ItemId" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="ApplicationId" />
            <input type="hidden" asp-for="ItemId" />

            <div class="mb-3">
                <label asp-for="SelectedTemplateId" class="form-label">Impact Template</label>
                <select asp-for="SelectedTemplateId" class="form-select" id="templateSelector">
                    <option value="">-- Select Impact Template --</option>
                    @foreach (var template in Model.Templates)
                    {
                        <option value="@template.Id"
                                data-description="@template.Description"
                                selected="@(Model.SelectedTemplateId == template.Id ? "selected" : null)">
                            @template.Name
                        </option>
                    }
                </select>
                <span asp-validation-for="SelectedTemplateId" class="text-danger"></span>
            </div>

            <div id="templateDescription" class="alert alert-info mb-3" style="display: none;"></div>

            <div id="parametersContainer">
                @if (Model.Parameters.Count > 0)
                {
                    <h5>Parameters</h5>
                    @for (int i = 0; i < Model.Parameters.Count; i++)
                    {
                        var param = Model.Parameters[i];
                        <div class="mb-3 parameter-field">
                            <label class="form-label">
                                @param.DisplayLabel
                                @if (param.IsRequired)
                                {
                                    <span class="text-danger">*</span>
                                }
                            </label>
                            <input type="hidden" name="Parameters[@i].ParameterId" value="@param.ParameterId" />
                            <input type="hidden" name="Parameters[@i].Name" value="@param.Name" />
                            <input type="hidden" name="Parameters[@i].DisplayLabel" value="@param.DisplayLabel" />
                            <input type="hidden" name="Parameters[@i].DataType" value="@param.DataType" />
                            <input type="hidden" name="Parameters[@i].IsRequired" value="@param.IsRequired" />
                            @switch (param.DataType)
                            {
                                case "Decimal":
                                    <input type="number" step="0.01" name="Parameters[@i].Value" value="@param.Value"
                                           class="form-control" @(param.IsRequired ? "required" : "") />
                                    break;
                                case "Integer":
                                    <input type="number" step="1" name="Parameters[@i].Value" value="@param.Value"
                                           class="form-control" @(param.IsRequired ? "required" : "") />
                                    break;
                                case "Date":
                                    <input type="date" name="Parameters[@i].Value" value="@param.Value"
                                           class="form-control" @(param.IsRequired ? "required" : "") />
                                    break;
                                default:
                                    <input type="text" name="Parameters[@i].Value" value="@param.Value"
                                           class="form-control" @(param.IsRequired ? "required" : "") />
                                    break;
                            }
                        </div>
                    }
                }
            </div>

            <div id="submitArea" style="@(Model.Parameters.Count > 0 ? "" : "display: none;")">
                <button type="submit" class="btn btn-primary">Save Impact</button>
            </div>
            <a asp-controller="Application" asp-action="Details" asp-route-id="@Model.ApplicationId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const templateSelector = document.getElementById('templateSelector');
            const parametersContainer = document.getElementById('parametersContainer');
            const submitArea = document.getElementById('submitArea');
            const templateDescription = document.getElementById('templateDescription');

            templateSelector.addEventListener('change', async function () {
                const templateId = this.value;

                // Show/hide description
                const selectedOption = this.options[this.selectedIndex];
                const description = selectedOption.getAttribute('data-description');
                if (description) {
                    templateDescription.textContent = description;
                    templateDescription.style.display = 'block';
                } else {
                    templateDescription.style.display = 'none';
                }

                if (!templateId) {
                    parametersContainer.innerHTML = '';
                    submitArea.style.display = 'none';
                    return;
                }

                try {
                    const response = await fetch(`/Application/@Model.ApplicationId/Item/TemplateParameters/${templateId}`);
                    if (!response.ok) throw new Error('Failed to load parameters');

                    const parameters = await response.json();

                    let html = '<h5>Parameters</h5>';
                    parameters.forEach(function (param, index) {
                        let inputHtml;
                        const requiredAttr = param.isRequired ? 'required' : '';
                        const requiredLabel = param.isRequired ? '<span class="text-danger">*</span>' : '';

                        switch (param.dataType) {
                            case 'Decimal':
                                inputHtml = `<input type="number" step="0.01" name="Parameters[${index}].Value" class="form-control" ${requiredAttr} />`;
                                break;
                            case 'Integer':
                                inputHtml = `<input type="number" step="1" name="Parameters[${index}].Value" class="form-control" ${requiredAttr} />`;
                                break;
                            case 'Date':
                                inputHtml = `<input type="date" name="Parameters[${index}].Value" class="form-control" ${requiredAttr} />`;
                                break;
                            default:
                                inputHtml = `<input type="text" name="Parameters[${index}].Value" class="form-control" ${requiredAttr} />`;
                                break;
                        }

                        html += `
                            <div class="mb-3 parameter-field">
                                <label class="form-label">${param.displayLabel} ${requiredLabel}</label>
                                <input type="hidden" name="Parameters[${index}].ParameterId" value="${param.id}" />
                                <input type="hidden" name="Parameters[${index}].Name" value="${param.name}" />
                                <input type="hidden" name="Parameters[${index}].DisplayLabel" value="${param.displayLabel}" />
                                <input type="hidden" name="Parameters[${index}].DataType" value="${param.dataType}" />
                                <input type="hidden" name="Parameters[${index}].IsRequired" value="${param.isRequired}" />
                                ${inputHtml}
                            </div>`;
                    });

                    parametersContainer.innerHTML = html;
                    submitArea.style.display = parameters.length > 0 ? '' : 'none';
                } catch (error) {
                    parametersContainer.innerHTML = '<div class="alert alert-danger">Failed to load template parameters.</div>';
                    submitArea.style.display = 'none';
                }
            });
        });
    </script>
}
