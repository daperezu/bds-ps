@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: "Change Password",
        Subtitle: "You must change your password before continuing."))

<div class="row mt-3">
    <div class="col-md-6">
        <form asp-action="ChangePassword" asp-controller="Account" method="post" data-testid="change-password-form">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label" asp-for="OldPassword">Current password</label>
                <input asp-for="OldPassword" type="password" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="OldPassword" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="NewPassword">New password</label>
                <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="ConfirmPassword">Confirm new password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            @await Html.PartialAsync("Components/_ActionBar",
                new ActionBarViewModel(new[]
                {
                    new ActionItem(
                        Label: "Change Password",
                        Class: ActionClass.Primary)
                }))
            <button type="submit" class="d-none" data-testid="change-password-submit">Submit</button>
        </form>
    </div>
</div>
