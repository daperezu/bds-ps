@{
    ViewData["Title"] = "Acceso denegado";
}

@await Html.PartialAsync("Components/_PageHeader",
    new PageHeaderViewModel(
        Title: "Acceso denegado",
        Subtitle: "No tiene permiso para ver este recurso."))

<div data-testid="access-denied">
    @await Html.PartialAsync("Components/_EmptyState",
        new EmptyStateViewModel(
            Headline: "403 Prohibido",
            Body: "Su sesión es válida, pero este recurso está restringido a otros roles. Si cree que es un error, contacte a un administrador del sistema.",
            Icon: "ti ti-lock-access",
            PrimaryAction: new ActionItem(
                Label: "Volver al inicio",
                Class: ActionClass.Primary,
                Url: Url.Action("Index", "Home") ?? "/")))
</div>
