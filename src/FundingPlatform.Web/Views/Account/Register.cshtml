@model FundingPlatform.Web.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Crear cuenta";
    Layout = "_AuthLayout";
}

<h2 class="card-title text-center mb-4">Cree su cuenta</h2>

<form asp-action="Register" asp-controller="Account" method="post">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3" data-testid="form-section" data-field="Email">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" autocomplete="email" />
        <span asp-validation-for="Email" class="invalid-feedback d-block"></span>
    </div>

    <div class="mb-3" data-testid="form-section" data-field="Password">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="Password" class="invalid-feedback d-block"></span>
    </div>

    <div class="mb-3" data-testid="form-section" data-field="ConfirmPassword">
        <label asp-for="ConfirmPassword" class="form-label"></label>
        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="ConfirmPassword" class="invalid-feedback d-block"></span>
    </div>

    <div class="row g-2">
        <div class="col-md-6">
            <div class="mb-3" data-testid="form-section" data-field="FirstName">
                <label asp-for="FirstName" class="form-label"></label>
                <input asp-for="FirstName" class="form-control" autocomplete="given-name" />
                <span asp-validation-for="FirstName" class="invalid-feedback d-block"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3" data-testid="form-section" data-field="LastName">
                <label asp-for="LastName" class="form-label"></label>
                <input asp-for="LastName" class="form-control" autocomplete="family-name" />
                <span asp-validation-for="LastName" class="invalid-feedback d-block"></span>
            </div>
        </div>
    </div>

    <div class="mb-3" data-testid="form-section" data-field="LegalId">
        <label asp-for="LegalId" class="form-label"></label>
        <input asp-for="LegalId" class="form-control" />
        <span asp-validation-for="LegalId" class="invalid-feedback d-block"></span>
    </div>

    <div class="form-footer">
        <button type="submit" class="btn btn-primary w-100">Crear cuenta</button>
    </div>
</form>

<div class="text-center text-secondary mt-3">
    ¿Ya tiene cuenta? <a asp-action="Login" asp-controller="Account">Inicie sesión aquí</a>
</div>
