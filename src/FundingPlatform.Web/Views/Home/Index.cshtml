@{
    ViewData["Title"] = "Home";
}

<div class="empty">
    <div class="empty-icon">
        <i class="ti ti-coin" style="font-size: 3rem;"></i>
    </div>
    <p class="empty-title">Funding Request Platform</p>
    <p class="empty-subtitle text-secondary">Submit and manage your funding applications.</p>
    <div class="empty-action">
        @if (User.Identity?.IsAuthenticated != true)
        {
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary me-2">
                <i class="ti ti-user-plus me-1"></i>Register
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">
                <i class="ti ti-login me-1"></i>Login
            </a>
        }
        else if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="Index" class="btn btn-primary me-2">
                <i class="ti ti-settings me-1"></i>Admin Dashboard
            </a>
            <a asp-controller="Review" asp-action="Index" class="btn btn-outline-primary">
                <i class="ti ti-clipboard-check me-1"></i>Review Queue
            </a>
        }
        else if (User.IsInRole("Reviewer"))
        {
            <a asp-controller="Review" asp-action="Index" class="btn btn-primary">
                <i class="ti ti-clipboard-check me-1"></i>Review Queue
            </a>
        }
        else
        {
            <a asp-controller="Application" asp-action="Index" class="btn btn-primary">
                <i class="ti ti-files me-1"></i>My Applications
            </a>
        }
    </div>
</div>
